        "id": "severe_hepatic_impairment_review",
        "priority": 90,
        "when": {
          "field": "child_pugh_class",
          "operator": "==",
          "value": "C"
        },
        "action": {
          "type": "consultant_review",
          "message": "Severe hepatic impairment entered. Review the official NCCP regimen and consultant plan before continuing."

      "proceed"
    ],
    "rules": [
      {
        "rule_id": "EXCLUSION_HYPERSENSITIVITY",
        "field": "hypersensitivity",
        "operator": "==",
        "value": true,
        "action": {
          "type": "contraindicated",
          "components": [
            "bevacizumab"
          ],
          "recommendation": "Do not administer bevacizumab; obtain consultant review."
        },
        "source": {
          "page": 3
        },
        "explanation": "Hypersensitivity is an exclusion."
      },
      {
        "rule_id": "PREGNANCY_REVIEW",
        "field": "pregnancy",
        "operator": "==",
        "value": true,
        "action": {
          "type": "contraindicated",
          "components": [
            "bevacizumab"
          ],
          "recommendation": "Do not administer bevacizumab during pregnancy; urgent consultant review is required."
        },
        "source": {
          "page": 3
        },
        "explanation": "Pregnancy is an exclusion."
      },
      {
        "rule_id": "COMBINATION_SCOPE_GAP",
        "all": [
          {
            "field": "treatment_context",
            "operator": "==",
            "value": "combination"
          },
          {
            "field": "partner_sact_assessed_separately",
            "operator": "==",
            "value": false
          }
        ],
        "action": {
          "type": "consultant_review",
          "components": [
            "combination regimen"
          ],
          "recommendation": "Complete the assessment of all partner SACT components before treatment; this JSON evaluates the bevacizumab component only."
        },
        "source": {
          "page": 2
        },
        "explanation": "Combination partner rules are outside this protocol component."
      },
      {
        "rule_id": "UNHEALED_WOUND_OR_RECENT_SURGERY",
        "field": "recent_major_surgery_or_unhealed_wound",
        "operator": "==",
        "value": true,
        "action": {
          "type": "withhold",
          "components": [
            "bevacizumab"
          ],
          "recommendation": "Withhold bevacizumab until the wound is fully healed and the postoperative interval is appropriate."
        },
        "source": {
          "page": 6
        },
        "explanation": "Bevacizumab can impair wound healing."
      },
      {
        "rule_id": "PLANNED_MAJOR_SURGERY",
        "field": "planned_major_surgery",
        "operator": "==",
        "value": true,
        "action": {
          "type": "withhold",
          "components": [
            "bevacizumab"
          ],
          "recommendation": "Withhold bevacizumab around major elective surgery according to the NCCP timing guidance and consultant plan."
        },
        "source": {
          "page": 6
        },
        "explanation": "Bevacizumab should be withheld for major elective surgery."
      },
      {
        "rule_id": "UNCONTROLLED_HYPERTENSION",
        "field": "uncontrolled_or_symptomatic_hypertension",
        "operator": "==",
        "value": true,
        "action": {
          "type": "withhold",
          "components": [
            "bevacizumab"
          ],
          "recommendation": "Withhold bevacizumab and start or adjust antihypertensive treatment."
        },
        "source": {
          "page": 5
        },
        "explanation": "Uncontrolled or symptomatic hypertension requires withholding."
      },
      {
        "rule_id": "PERSISTENT_G3_OR_G4_HYPERTENSION",
        "field": "hypertension_grade",
        "operator": ">=",
        "value": 3,
        "action": {
          "type": "discontinue",
          "components": [
            "bevacizumab"
          ],
          "recommendation": "Discontinue bevacizumab for grade 4 or persisting grade 3 hypertension."
        },
        "source": {
          "page": 5
        },
        "explanation": "Persistent severe hypertension requires discontinuation."
      },
      {
        "rule_id": "SEVERE_UNCONTROLLED_BP",
        "field": "severe_bp_uncontrolled",
        "operator": "==",
        "value": true,
        "action": {
          "type": "discontinue",
          "components": [
            "bevacizumab"
          ],
          "recommendation": "Discontinue bevacizumab for severe blood pressure >200/110 mmHg that remains uncontrolled."
        },
        "source": {
          "page": 7
        },
        "explanation": "Severe uncontrolled hypertension requires discontinuation."
      },
      {
        "rule_id": "HYPERTENSIVE_CRISIS_PRES",
        "field": "hypertensive_crisis_or_encephalopathy",
        "operator": "==",
        "value": true,
        "action": {
          "type": "permanently_discontinue",
          "components": [
            "bevacizumab"
          ],
          "recommendation": "Permanently discontinue bevacizumab and manage urgently."
        },
        "source": {
          "page": 7
        },
        "explanation": "Hypertensive crisis/encephalopathy requires permanent discontinuation."
      },
      {
        "rule_id": "PROTEIN_DIPSTICK_2_3",
        "field": "proteinuria_dipstick",
        "operator": "in",
        "value": [
          "2+",
          "3+"
        ],
        "action": {
          "type": "proceed_with_caution",
          "components": [
            "bevacizumab"
          ],
          "recommendation": "Bevacizumab may proceed while a 24-hour urine collection is arranged before the next dose."
        },
        "source": {
          "page": 5
        },
        "explanation": "2+ or 3+ dipstick requires quantification."
      },
      {
        "rule_id": "PROTEIN_DIPSTICK_4",
        "field": "proteinuria_dipstick",
        "operator": "==",
        "value": "4+",
        "action": {
          "type": "withhold",
          "components": [
            "bevacizumab"
          ],
          "recommendation": "Withhold bevacizumab and obtain a 24-hour urine protein measurement."
        },
        "source": {
          "page": 5
        },
        "explanation": "4+ dipstick requires withholding pending quantification."
      },
      {
        "rule_id": "PROTEIN_2_TO_4",
        "all": [
          {
            "field": "urine_protein_g_24h",
            "operator": ">",
            "value": 2
          },
          {
            "field": "urine_protein_g_24h",
            "operator": "<=",
            "value": 4
          }
        ],
        "action": {
          "type": "withhold",
          "components": [
            "bevacizumab"
          ],
          "recommendation": "Hold bevacizumab; repeat 24-hour urine protein every 2 weeks and resume when ≤2 g/24 h."
        },
        "source": {
          "page": 5
        },
        "explanation": "Urine protein >2–4 g/24 h requires holding."
      },
      {
        "rule_id": "PROTEIN_OVER_4",
        "field": "urine_protein_g_24h",
        "operator": ">",
        "value": 4,
        "action": {
          "type": "discontinue",
          "components": [
            "bevacizumab"
          ],
          "recommendation": "Discontinue bevacizumab for urine protein >4 g/24 h."
        },
        "source": {
          "page": 5
        },
        "explanation": "Severe proteinuria requires discontinuation."
      },
      {
        "rule_id": "GRADE4_FISTULA",
        "field": "fistula_grade",
        "operator": ">=",
        "value": 4,
        "action": {
          "type": "discontinue",
          "components": [
            "bevacizumab"
          ],
          "recommendation": "Discontinue bevacizumab for grade 4 fistula."
        },
        "source": {
          "page": 5
        },
        "explanation": "Grade 4 fistula requires discontinuation."
      },
      {
        "rule_id": "THROMBOEMBOLIC_G4",
        "field": "thromboembolic_event_grade",
        "operator": ">=",
        "value": 4,
        "action": {
          "type": "discontinue",
          "components": [
            "bevacizumab"
          ],
          "recommendation": "Discontinue bevacizumab for grade 4 thromboembolic toxicity."
        },
        "source": {
          "page": 5
        },
        "explanation": "Grade 4 thromboembolic event requires discontinuation."
      },
      {
        "rule_id": "ARTERIAL_THROMBOEMBOLIC_EVENT",
        "field": "arterial_thromboembolic_event",
        "operator": "==",
        "value": true,
        "action": {
          "type": "permanently_discontinue",
          "components": [
            "bevacizumab"
          ],
          "recommendation": "Permanently discontinue bevacizumab after an arterial thromboembolic event."
        },
        "source": {
          "page": 7
        },
        "explanation": "Arterial thromboembolism requires permanent discontinuation."
      },
      {
        "rule_id": "HAEMORRHAGE_G3PLUS",
        "field": "haemorrhage_grade",
        "operator": ">=",
        "value": 3,
        "action": {
          "type": "discontinue",
          "components": [
            "bevacizumab"
          ],
          "recommendation": "Discontinue bevacizumab for grade 3 or higher haemorrhage."
        },
        "source": {
          "page": 5
        },
        "explanation": "Severe haemorrhage requires discontinuation."
      },
      {
        "rule_id": "GI_PERFORATION",
        "field": "gi_perforation",
        "operator": "==",
        "value": true,
        "action": {
          "type": "permanently_discontinue",
          "components": [
            "bevacizumab"
          ],
          "recommendation": "Permanently discontinue bevacizumab for gastrointestinal perforation."
        },
        "source": {
          "page": 5
        },
        "explanation": "GI perforation requires permanent discontinuation."
      },
      {
        "rule_id": "NECROTISING_FASCIITIS",
        "field": "necrotising_fasciitis",
        "operator": "==",
        "value": true,
        "action": {
          "type": "discontinue",
          "components": [
            "bevacizumab"
          ],
          "recommendation": "Discontinue bevacizumab and institute urgent treatment for necrotising fasciitis."
        },
        "source": {
          "page": 6
        },
        "explanation": "Necrotising fasciitis requires discontinuation."
      },
      {
        "rule_id": "PRES",
        "field": "pres_confirmed",
        "operator": "==",
        "value": true,
        "action": {
          "type": "discontinue",
          "components": [
            "bevacizumab"
          ],
          "recommendation": "Discontinue bevacizumab and urgently manage confirmed PRES."
        },
        "source": {
          "page": 7
        },
        "explanation": "PRES requires discontinuation."
      },
      {
        "rule_id": "FBC_REVIEW_ONLY",
        "field": "fbc_clinical_concern",
        "operator": "==",
        "value": true,
        "action": {
          "type": "consultant_review",
          "components": [
            "bevacizumab"
          ],
          "recommendation": "Review the FBC abnormality clinically. No cycle-by-cycle numerical ANC or platelet hold threshold is encoded in NCCP 00215."
        },
        "source": {
          "page": 4
        },
        "explanation": "Routine FBC is monitored without a protocol-defined dose threshold."
      },
      {
        "rule_id": "ORGAN_FUNCTION_REVIEW",
        "field": "renal_or_hepatic_clinical_concern",
        "operator": "==",
        "value": true,
        "action": {
          "type": "consultant_review",
          "components": [
            "bevacizumab"
          ],
          "recommendation": "Review renal or hepatic abnormality with the consultant; no validated dose adjustment is specified."
        },
        "source": {
          "page": 4
        },
        "explanation": "Renal/hepatic impairment lacks a defined dose-adjustment table."
      }
    ]
  },

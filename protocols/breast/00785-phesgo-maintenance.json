  "rule_engine": {
    "conflict_policy": "most_restrictive_action_wins",
    "missing_data_policy": "report_unassessed_coverage_gap",
    "actions_ranked_most_to_least_restrictive": [
      "permanently_discontinue",
      "contraindicated",
      "discontinue",
      "cease",
      "omit",
      "withhold_then_reduce",
      "withhold",
      "delay_then_dose_reduce",
      "delay",
      "consultant_review",
      "dose_reduce_two_levels",
      "dose_reduce_one_level",
      "dose_reduce",
      "proceed_with_caution",
      "proceed"
    ],
    "rules": [
      {
        "rule_id": "EXCLUSION_HYPERSENSITIVITY",
        "field": "relevant_drug_hypersensitivity",
        "operator": "==",
        "value": true,
        "action": {
          "type": "contraindicated",
          "components": [
            "pertuzumab",
            "trastuzumab"
          ],
          "recommendation": "Do not administer; obtain consultant review."
        },
        "source": {
          "page": 2
        },
        "explanation": "Relevant hypersensitivity is an exclusion."
      },
      {
        "rule_id": "EXCLUSION_PREGNANCY_BREASTFEEDING",
        "any": [
          {
            "field": "pregnancy",
            "operator": "==",
            "value": true
          },
          {
            "field": "breastfeeding",
            "operator": "==",
            "value": true
          }
        ],
        "action": {
          "type": "contraindicated",
          "components": [
            "pertuzumab",
            "trastuzumab"
          ],
          "recommendation": "Do not administer during pregnancy or breastfeeding; urgent consultant review required."
        },
        "source": {
          "page": 2
        },
        "explanation": "Pregnancy and breastfeeding are exclusions."
      },
      {
        "rule_id": "CARDIAC_DISEASE_EXCLUSION",
        "field": "clinically_significant_cardiac_disease",
        "operator": "==",
        "value": true,
        "action": {
          "type": "contraindicated",
          "components": [
            "pertuzumab",
            "trastuzumab"
          ],
          "recommendation": "Do not proceed without consultant/cardiology review."
        },
        "source": {
          "page": 2
        },
        "explanation": "Clinically significant cardiac disease is an exclusion."
      },
      {
        "rule_id": "FBC_CLINICAL_REVIEW",
        "field": "fbc_clinical_concern",
        "operator": "==",
        "value": true,
        "action": {
          "type": "consultant_review",
          "components": [
            "pertuzumab",
            "trastuzumab"
          ],
          "recommendation": "Review the FBC abnormality clinically; the source does not define a numerical cytotoxic count hold for this maintenance regimen."
        },
        "source": {
          "page": 2
        },
        "explanation": "FBC is monitored, but no numerical count threshold is specified."
      },
      {
        "rule_id": "LVEF_WITHHOLD_LOW",
        "field": "lvef_percent",
        "operator": "<",
        "value": 40,
        "action": {
          "type": "withhold",
          "components": [
            "pertuzumab",
            "trastuzumab"
          ],
          "recommendation": "Withhold pertuzumab/trastuzumab (Phesgo®) for at least 3 weeks and repeat LVEF assessment."
        },
        "source": {
          "page": 4,
          "table": "Table 3"
        },
        "explanation": "LVEF below 40% requires withholding."
      },
      {
        "rule_id": "LVEF_WITHHOLD_40_45",
        "all": [
          {
            "field": "lvef_percent",
            "operator": ">=",
            "value": 40
          },
          {
            "field": "lvef_percent",
            "operator": "<=",
            "value": 45
          },
          {
            "field": "lvef_drop_points",
            "operator": ">=",
            "value": 10
          }
        ],
        "action": {
          "type": "withhold",
          "components": [
            "pertuzumab",
            "trastuzumab"
          ],
          "recommendation": "Withhold pertuzumab/trastuzumab (Phesgo®) for at least 3 weeks and repeat LVEF assessment."
        },
        "source": {
          "page": 4,
          "table": "Table 3"
        },
        "explanation": "LVEF 40–45% with a fall of at least 10 points requires withholding."
      },
      {
        "rule_id": "SYMPTOMATIC_HEART_FAILURE",
        "field": "symptomatic_heart_failure",
        "operator": "==",
        "value": true,
        "action": {
          "type": "discontinue",
          "components": [
            "pertuzumab",
            "trastuzumab"
          ],
          "recommendation": "Discontinue treatment for symptomatic heart failure and obtain urgent cardiology review."
        },
        "source": {
          "page": 4,
          "table": "Table 3"
        },
        "explanation": "Symptomatic heart failure requires discontinuation."
      },
      {
        "rule_id": "HYPERSENSITIVITY_G4",
        "field": "hypersensitivity_grade",
        "operator": ">=",
        "value": 4,
        "action": {
          "type": "discontinue",
          "components": [
            "pertuzumab",
            "trastuzumab"
          ],
          "recommendation": "Discontinue treatment for grade 4 hypersensitivity/anaphylaxis."
        },
        "source": {
          "page": 4,
          "table": "Table 3"
        },
        "explanation": "Grade 4 hypersensitivity requires discontinuation."
      },
      {
        "rule_id": "INFUSION_REACTION_G1_G2",
        "all": [
          {
            "field": "hypersensitivity_grade",
            "operator": ">=",
            "value": 1
          },
          {
            "field": "hypersensitivity_grade",
            "operator": "<=",
            "value": 2
          }
        ],
        "action": {
          "type": "proceed_with_caution",
          "components": [
            "pertuzumab",
            "trastuzumab"
          ],
          "recommendation": "Slow or interrupt the infusion and provide appropriate supportive treatment; resume only after symptoms resolve."
        },
        "source": {
          "page": 5
        },
        "explanation": "Mild/moderate infusion reactions require interruption or slowing and supportive care."
      },
      {
        "rule_id": "DIARRHOEA_NOT_CONTROLLED",
        "all": [
          {
            "field": "diarrhoea_grade",
            "operator": ">=",
            "value": 3
          },
          {
            "field": "diarrhoea_not_improving",
            "operator": "==",
            "value": true
          }
        ],
        "action": {
          "type": "withhold",
          "components": [
            "pertuzumab"
          ],
          "recommendation": "Consider interrupting pertuzumab until severe/prolonged diarrhoea is controlled."
        },
        "source": {
          "page": 5
        },
        "explanation": "Pertuzumab interruption should be considered if severe diarrhoea does not improve."
      },
      {
        "rule_id": "MISSED_DOSE_RELOAD",
        "field": "weeks_since_last_dose",
        "operator": ">=",
        "value": 6,
        "action": {
          "type": "proceed_with_caution",
          "components": [
            "pertuzumab",
            "trastuzumab"
          ],
          "recommendation": "The interval is 6 weeks or longer: re-administer the pertuzumab 840 mg and trastuzumab 8 mg/kg loading doses, then resume the 3-weekly maintenance schedule."
        },
        "source": {
          "page": 3,
          "table": "Table 1"
        },
        "explanation": "A gap of at least 6 weeks requires reloading doses."
      }
    ]
  },

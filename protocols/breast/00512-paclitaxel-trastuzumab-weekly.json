  "rule_engine": {
    "conflict_policy": "most_restrictive_action_wins",
    "missing_data_policy": "report_unassessed_coverage_gap",
    "actions_ranked_most_to_least_restrictive": [
      "permanently_discontinue",
      "contraindicated",
      "discontinue",
      "cease",
      "omit",
      "withhold_then_reduce",
      "withhold",
      "delay_then_dose_reduce",
      "delay",
      "consultant_review",
      "dose_reduce_two_levels",
      "dose_reduce_one_level",
      "dose_reduce",
      "proceed_with_caution",
      "proceed"
    ],
    "rules": [
      {
        "rule_id": "EXCLUSION_HYPERSENSITIVITY",
        "field": "hypersensitivity",
        "operator": "==",
        "value": true,
        "action": {
          "type": "contraindicated",
          "components": [
            "paclitaxel",
            "trastuzumab"
          ],
          "recommendation": "Do not administer this regimen; obtain consultant review."
        },
        "source": {
          "page": 2
        },
        "explanation": "Relevant hypersensitivity is an exclusion."
      },
      {
        "rule_id": "EXCLUSION_PREGNANCY_LACTATION",
        "any": [
          {
            "field": "pregnancy",
            "operator": "==",
            "value": true
          },
          {
            "field": "breastfeeding",
            "operator": "==",
            "value": true
          }
        ],
        "action": {
          "type": "contraindicated",
          "components": [
            "paclitaxel",
            "trastuzumab"
          ],
          "recommendation": "Do not administer; urgent consultant review required."
        },
        "source": {
          "page": 2
        },
        "explanation": "Pregnancy or breastfeeding is an exclusion/caution for this regimen."
      },
      {
        "rule_id": "ACTIVE_INFECTION",
        "field": "active_infection",
        "operator": "==",
        "value": true,
        "action": {
          "type": "withhold",
          "components": [
            "paclitaxel",
            "trastuzumab"
          ],
          "recommendation": "Withhold and assess/treat infection; discuss with consultant."
        },
        "source": {
          "page": 3
        },
        "explanation": "Clinically significant infection requires review before treatment."
      },
      {
        "rule_id": "ANC_LOW",
        "field": "anc",
        "operator": "<",
        "value": 1.0,
        "action": {
          "type": "delay",
          "components": [
            "paclitaxel",
            "trastuzumab"
          ],
          "recommendation": "Delay treatment and repeat FBC; discuss dose modification with consultant."
        },
        "source": {
          "page": 4
        },
        "explanation": "ANC below treatment threshold."
      },
      {
        "rule_id": "PLATELETS_LOW",
        "field": "platelets",
        "operator": "<",
        "value": 75,
        "action": {
          "type": "delay",
          "components": [
            "paclitaxel",
            "trastuzumab"
          ],
          "recommendation": "Delay treatment and repeat FBC; discuss dose modification with consultant."
        },
        "source": {
          "page": 4
        },
        "explanation": "Platelets below treatment threshold."
      },
      {
        "rule_id": "DIARRHOEA_G3PLUS",
        "field": "diarrhoea_grade",
        "operator": ">=",
        "value": 3,
        "action": {
          "type": "withhold_then_reduce",
          "components": [
            "paclitaxel",
            "trastuzumab"
          ],
          "recommendation": "Withhold until recovery and consider dose reduction according to the NCCP table."
        },
        "source": {
          "page": 5
        },
        "explanation": "Severe diarrhoea requires withholding and dose review."
      },
      {
        "rule_id": "STOMATITIS_G3PLUS",
        "field": "stomatitis_grade",
        "operator": ">=",
        "value": 3,
        "action": {
          "type": "withhold_then_reduce",
          "components": [
            "paclitaxel",
            "trastuzumab"
          ],
          "recommendation": "Withhold until recovery and consider dose reduction according to the NCCP table."
        },
        "source": {
          "page": 5
        },
        "explanation": "Severe mucositis requires withholding and dose review."
      },
      {
        "rule_id": "LVEF_BELOW50",
        "field": "lvef_percent",
        "operator": "<",
        "value": 50,
        "action": {
          "type": "withhold",
          "components": [
            "trastuzumab"
          ],
          "recommendation": "Withhold trastuzumab and arrange cardiac/consultant review."
        },
        "source": {
          "page": 5
        },
        "explanation": "Reduced LVEF requires trastuzumab interruption."
      },
      {
        "rule_id": "LVEF_DROP",
        "field": "lvef_drop_percent",
        "operator": ">=",
        "value": 10,
        "action": {
          "type": "withhold",
          "components": [
            "trastuzumab"
          ],
          "recommendation": "Withhold trastuzumab and repeat cardiac assessment per NCCP."
        },
        "source": {
          "page": 5
        },
        "explanation": "Clinically significant LVEF decline."
      },
      {
        "rule_id": "PACLITAXEL_NEURO_G2",
        "field": "neuropathy_grade",
        "operator": ">=",
        "value": 2,
        "action": {
          "type": "withhold_then_reduce",
          "components": [
            "paclitaxel"
          ],
          "recommendation": "Withhold paclitaxel until improvement and reduce according to NCCP."
        },
        "source": {
          "page": 6
        },
        "explanation": "Paclitaxel neuropathy requires modification."
      },
      {
        "rule_id": "TRAS_IRR_G3",
        "field": "trastuzumab_infusion_reaction_grade",
        "operator": ">=",
        "value": 3,
        "action": {
          "type": "discontinue",
          "components": [
            "trastuzumab"
          ],
          "recommendation": "Stop infusion and obtain urgent medical review; permanent discontinuation may be required."
        },
        "source": {
          "page": 7
        },
        "explanation": "Severe infusion reaction."
      }
    ]
  },

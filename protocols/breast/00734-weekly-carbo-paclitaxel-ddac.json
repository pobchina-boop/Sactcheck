        "rule_id": "PACLITAXEL_NEUROPATHY_FIRST_OCCURRENCE",
        "all": [
          {
            "field": "neuropathy_grade",
            "operator": ">=",
            "value": 2
          },
          {
            "field": "neuropathy_occurrence",
            "operator": "==",
            "value": 1
          }
        ],
        "action": {
          "type": "dose_reduce",
          "components": [
            "paclitaxel"
          ],
          "absolute_reduction": {
            "value": 10,
            "unit": "mg/m2"
          }
        },
        "source": {
          "page": 9,
          "table": 5
        }
      },
      {
        "rule_id": "PACLITAXEL_NEUROPATHY_PERSISTENT_OR_SECOND",
        "all": [
          {
            "field": "neuropathy_grade",
            "operator": ">=",
            "value": 2
          },
          {
            "field": "neuropathy_persistent_or_second_occurrence",
            "operator": "==",
            "value": true
          }
        ],
        "action": {
          "type": "dose_reduce",
          "components": [
            "paclitaxel"
          ],
          "absolute_reduction": {
            "value": 10,
            "unit": "mg/m2"
          },
          "relative_to_current_dose": true
        },
        "source": {
          "page": 9,
          "table": 5
        }
      },
      {
        "rule_id": "PACLITAXEL_OTHER_GRADE2_NON_HAEM",
        "all": [
          {
            "field": "other_non_haematological_toxicity_grade",
            "operator": "==",
            "value": 2
          }
        ],
        "action": {
          "type": "withhold_then_reduce",
          "components": [
            "paclitaxel"
          ],
          "resume_when_grade_lte": 1,
          "absolute_reduction": {
            "value": 10,
            "unit": "mg/m2"
          }
        },
        "source": {
          "page": 9,
          "table": 5
        }
      },
      {
        "rule_id": "PACLITAXEL_GRADE3_PLUS_DISCONTINUE",
        "all": [
          {
            "field": "paclitaxel_non_haematological_toxicity_grade",
            "operator": ">=",
            "value": 3
          }
        ],
        "action": {
          "type": "discontinue",
          "components": [
            "paclitaxel"
          ]
        },
        "source": {
          "page": 9,
          "table": 5
        }
      },
      {
        "rule_id": "PACLITAXEL_MAX_REDUCTIONS_OR_DELAY",
        "any": [

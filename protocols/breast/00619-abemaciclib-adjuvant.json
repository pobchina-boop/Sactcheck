  "rule_engine": {
    "conflict_policy": "Return the most restrictive applicable action and display every triggered rule.",
    "missing_data_policy": "Evaluate only supplied values. Do not infer missing values and do not block a partial assessment.",
    "actions_ranked_most_to_least_restrictive": [
      "permanently_discontinue",
      "contraindicated",
      "discontinue",
      "omit",
      "withhold",
      "delay",
      "consultant_review",
      "dose_reduce",
      "proceed"
    ],
    "rules": [
      {
        "rule_id": "BASELINE_ANC_REVIEW",
        "any": [
          {
            "field": "anc_x10e9_l",
            "operator": "<",
            "value": 1.5
          }
        ],
        "action": {
          "type": "consultant_review",
          "components": [
            "whole_regimen"
          ]
        },
        "source": {
          "page": 3
        },
        "explanation": "Before initiation, ANC ≥1.5 ×10⁹/L is recommended."
      },
      {
        "rule_id": "BASELINE_PLATELET_REVIEW",
        "any": [
          {
            "field": "platelets_x10e9_l",
            "operator": "<",
            "value": 100
          }
        ],
        "action": {
          "type": "consultant_review",
          "components": [
            "whole_regimen"
          ]
        },
        "source": {
          "page": 3
        },
        "explanation": "Before initiation, platelets ≥100 ×10⁹/L are recommended."
      },
      {
        "rule_id": "BASELINE_HB_REVIEW",
        "any": [
          {
            "field": "hb_g_dl",
            "operator": "<",
            "value": 8
          }
        ],
        "action": {
          "type": "consultant_review",
          "components": [
            "whole_regimen"
          ]
        },
        "source": {
          "page": 3
        },
        "explanation": "Before initiation, haemoglobin ≥8 g/dL is recommended."
      },
      {
        "rule_id": "HAEM_GRADE3_HOLD",
        "any": [
          {
            "field": "haematological_toxicity_grade",
            "operator": ">=",
            "value": 3
          }
        ],
        "action": {
          "type": "withhold",
          "components": [
            "whole_regimen"
          ]
        },
        "source": {
          "page": 3
        },
        "explanation": "Grade 3 or 4 haematological toxicity requires suspension until recovery to grade 2 or lower."
      },
      {
        "rule_id": "DIARRHOEA_GRADE2_PLUS",
        "any": [
          {
            "field": "diarrhoea_grade",
            "operator": ">=",
            "value": 2
          }
        ],
        "action": {
          "type": "withhold",
          "components": [
            "whole_regimen"
          ]
        },
        "source": {
          "page": 3
        },
        "explanation": "Persistent or recurrent grade 2, or grade 3–4 diarrhoea, requires interruption and protocol-directed management."
      },
      {
        "rule_id": "HEPATIC_GRADE3_PLUS",
        "any": [
          {
            "field": "alt_grade",
            "operator": ">=",
            "value": 3
          },
          {
            "field": "ast_grade",
            "operator": ">=",
            "value": 3
          }
        ],
        "action": {
          "type": "withhold",
          "components": [
            "whole_regimen"
          ]
        },
        "source": {
          "page": 3
        },
        "explanation": "Grade 3 or higher transaminase toxicity requires interruption and dose-modification review."
      },
      {
        "rule_id": "CHILD_PUGH_C",
        "any": [
          {
            "field": "child_pugh_class",
            "operator": "==",
            "value": "C"
          }
        ],
        "action": {
          "type": "dose_reduce",
          "components": [
            "whole_regimen"
          ]
        },
        "source": {
          "page": 3
        },
        "explanation": "Child–Pugh C requires reducing abemaciclib dosing frequency to once daily."
      },
      {
        "rule_id": "SEVERE_RENAL_REVIEW",
        "field": "renal_band",
        "operator": "in",
        "value": [
          "severe",
          "dialysis"
        ],
        "action": {
          "type": "consultant_review",
          "components": [
            "abemaciclib"
          ],
          "recommendation": "Specialist oncology/pharmacy review."
        },
        "source": {
          "page": 4
        },
        "explanation": "Severe renal impairment or dialysis requires specialist review because evidence is limited."
      }
    ]
  },

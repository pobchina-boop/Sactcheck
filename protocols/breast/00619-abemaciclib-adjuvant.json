          ]
        },
        "source": {
          "page": 3
        },
        "explanation": "Before initiation, platelets \u2265100 \u00d710\u2079/L are recommended."
      },
      {
        "rule_id": "BASELINE_HB_REVIEW",
        "any": [
          {
            "field": "hb_g_dl",
            "operator": "<",
            "value": 8
          }
        ],
        "action": {
          "type": "consultant_review",
          "components": [
            "whole_regimen"
          ]
        },
        "source": {
          "page": 3
        },
        "explanation": "Before initiation, haemoglobin \u22658 g/dL is recommended."
      },
      {
        "rule_id": "HAEM_GRADE3_HOLD",
        "any": [
          {
            "field": "haematological_toxicity_grade",
            "operator": ">=",
            "value": 3
          }
        ],
        "action": {
          "type": "withhold",
          "components": [
            "whole_regimen"
          ]
        },
        "source": {
          "page": 3
        },
        "explanation": "Grade 3 or 4 haematological toxicity requires suspension until recovery to grade 2 or lower."
      },
      {
        "rule_id": "DIARRHOEA_GRADE2_PLUS",
        "any": [
          {
            "field": "diarrhoea_grade",
            "operator": ">=",
            "value": 2
          }
        ],
        "action": {
          "type": "withhold",
          "components": [
            "whole_regimen"
          ]
        },
        "source": {
          "page": 3
        },
        "explanation": "Persistent or recurrent grade 2, or grade 3\u20134 diarrhoea, requires interruption and protocol-directed management."
      },
      {
        "rule_id": "HEPATIC_GRADE3_PLUS",
        "any": [
          {
            "field": "alt_grade",
            "operator": ">=",
            "value": 3
          },
          {
            "field": "ast_grade",
            "operator": ">=",
            "value": 3
          }
        ],
        "action": {
          "type": "withhold",
          "components": [
            "whole_regimen"
          ]
        },
        "source": {
          "page": 3
        },
        "explanation": "Grade 3 or higher transaminase toxicity requires interruption and dose-modification review."
      },
      {
        "rule_id": "CHILD_PUGH_C",
        "any": [
          {
            "field": "child_pugh_class",
            "operator": "==",
            "value": "C"
          }
        ],
        "action": {
          "type": "dose_reduce",
          "components": [
            "whole_regimen"
          ]
        },
        "source": {
          "page": 3
        },
        "explanation": "Child\u2013Pugh C requires reducing abemaciclib dosing frequency to once daily."

  "rule_engine": {
    "conflict_policy": "Return the most restrictive applicable action and display every triggered rule.",
    "missing_data_policy": "Evaluate only supplied values. Do not infer missing values and do not block a partial assessment.",
    "actions_ranked_most_to_least_restrictive": [
      "permanently_discontinue",
      "contraindicated",
      "discontinue",
      "omit",
      "withhold",
      "delay",
      "consultant_review",
      "dose_reduce",
      "proceed"
    ],
    "rules": [
      {
        "rule_id": "TCH_COUNTS_DELAY",
        "any": [
          {
            "field": "anc_x10e9_l",
            "operator": "<",
            "value": 1.0
          },
          {
            "field": "platelets_x10e9_l",
            "operator": "<",
            "value": 100
          }
        ],
        "action": {
          "type": "delay",
          "components": [
            "whole_regimen"
          ]
        },
        "source": {
          "page": 3
        },
        "explanation": "ANC below 1.0 ×10⁹/L or platelets below 100 ×10⁹/L triggers delay until recovery."
      },
      {
        "rule_id": "TCH_FULL_DOSE",
        "all": [
          {
            "field": "anc_x10e9_l",
            "operator": ">=",
            "value": 1.5
          },
          {
            "field": "platelets_x10e9_l",
            "operator": ">",
            "value": 100
          }
        ],
        "action": {
          "type": "proceed",
          "components": [
            "whole_regimen"
          ]
        },
        "source": {
          "page": 3
        },
        "explanation": "Counts meet the full-dose TCH threshold."
      },
      {
        "rule_id": "TCH_INTERMEDIATE_ANC",
        "any": [
          {
            "field": "anc_x10e9_l",
            "operator": "between_inclusive",
            "value": [
              1.0,
              1.49
            ]
          }
        ],
        "action": {
          "type": "consultant_review",
          "components": [
            "whole_regimen"
          ]
        },
        "source": {
          "page": 3
        },
        "explanation": "ANC 1.0–1.49 ×10⁹/L requires applying the NCCP G-CSF versus 75% dose pathway."
      },
      {
        "rule_id": "TCH_NEUROPATHY",
        "any": [
          {
            "field": "neuropathy_grade",
            "operator": ">=",
            "value": 2
          }
        ],
        "action": {
          "type": "consultant_review",
          "components": [
            "whole_regimen"
          ]
        },
        "source": {
          "page": 3
        },
        "explanation": "Grade 2 or higher neuropathy requires docetaxel review."
      }
    ]
  },

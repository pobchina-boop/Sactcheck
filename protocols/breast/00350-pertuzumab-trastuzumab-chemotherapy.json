      "dose_reduce",
      "proceed_with_caution",
      "proceed"
    ],
    "rules": [
      {
        "rule_id": "EXCLUSION_HYPERSENSITIVITY",
        "field": "relevant_drug_hypersensitivity",
        "operator": "==",
        "value": true,
        "action": {
          "type": "contraindicated",
          "components": [
            "docetaxel",
            "carboplatin",
            "trastuzumab",
            "pertuzumab"
          ],
          "recommendation": "Do not administer TCHP; obtain consultant review."
        },
        "source": {
          "page": 4
        },
        "explanation": "Relevant hypersensitivity is an exclusion."
      },
      {
        "rule_id": "EXCLUSION_PREGNANCY_BREASTFEEDING",
        "any": [
          {
            "field": "pregnancy",
            "operator": "==",
            "value": true
          },
          {
            "field": "breastfeeding",
            "operator": "==",
            "value": true
          }
        ],
        "action": {
          "type": "contraindicated",
          "components": [
            "docetaxel",
            "carboplatin",
            "trastuzumab",
            "pertuzumab"
          ],
          "recommendation": "Do not administer TCHP during pregnancy or breastfeeding; urgent consultant review required."
        },
        "source": {
          "page": 4
        },
        "explanation": "Pregnancy and breastfeeding are exclusions."
      },
      {
        "rule_id": "CARDIAC_DISEASE_EXCLUSION",
        "field": "clinically_significant_cardiac_disease",
        "operator": "==",
        "value": true,
        "action": {
          "type": "contraindicated",
          "components": [
            "trastuzumab",
            "pertuzumab"
          ],
          "recommendation": "Do not proceed with HER2-directed treatment without consultant/cardiology review."
        },
        "source": {
          "page": 4
        },
        "explanation": "Clinically significant cardiac disease is an exclusion."
      },
      {
        "rule_id": "ACTIVE_INFECTION_REVIEW",
        "field": "active_infection",
        "operator": "==",
        "value": true,
        "action": {
          "type": "withhold",
          "components": [
            "docetaxel",
            "carboplatin",
            "trastuzumab",
            "pertuzumab"
          ],
          "recommendation": "Withhold treatment and assess/treat the infection before proceeding."
        },
        "source": {
          "page": 4
        },
        "explanation": "Clinically significant infection requires review before systemic treatment."
      },
      {
        "rule_id": "BASELINE_LVEF_BELOW55",
        "all": [
          {
            "field": "assessment_stage",
            "operator": "==",
            "value": "baseline"
          },
          {
            "field": "lvef_percent",
            "operator": "<",
            "value": 55
          }
        ],
        "action": {
          "type": "contraindicated",
          "components": [
            "trastuzumab",
            "pertuzumab"
          ],
          "recommendation": "Pretreatment LVEF is below the encoded eligibility value of 55%; obtain consultant/cardiology review."
        },
        "source": {
          "page": 3
        },
        "explanation": "Pretreatment LVEF should be at least 55%."
      },
      {
        "rule_id": "BASELINE_NEUROPATHY_G2_PLUS",
        "all": [
          {
            "field": "assessment_stage",
            "operator": "==",
            "value": "baseline"
          },
          {
            "field": "neuropathy_grade",
            "operator": ">=",
            "value": 2
          }
        ],
        "action": {
          "type": "contraindicated",
          "components": [
            "docetaxel"
          ],
          "recommendation": "Baseline grade 2 or greater sensory/motor neuropathy is an exclusion for this regimen."
        },
        "source": {
          "page": 4
        },
        "explanation": "Baseline grade 2 or greater neuropathy is excluded."
      },
      {
        "rule_id": "COUNTS_LOW_IMMEDIATE_DELAY",
        "any": [
          {
            "field": "anc",
            "operator": "<",
            "value": 1.0
          },
          {
            "field": "platelets",
            "operator": "<=",
            "value": 100
          }
        ],
        "action": {
          "type": "delay",
          "components": [
            "docetaxel",
            "carboplatin"
          ],
          "recommendation": "Delay docetaxel and carboplatin for low counts. Enter the selected haematological management strategy to refine the post-recovery dose plan."
        },
        "source": {
          "page": 5,
          "table": "Table 2"
        },
        "explanation": "ANC below 1.0 or platelets 100 or below requires an immediate treatment delay; the selected G-CSF or dose-reduction pathway refines subsequent dosing."
      },
      {
        "rule_id": "COUNTS_INTERMEDIATE_REDUCE",
        "all": [
          {
            "field": "anc",
            "operator": ">=",
            "value": 1.0
          },
          {
            "field": "anc",
            "operator": "<",
            "value": 1.5
          },
          {
            "field": "platelets",
            "operator": ">",
            "value": 100
          },
          {
            "field": "gcsf_strategy",
            "operator": "==",
            "value": "dose_reduction"
          }
        ],
        "action": {
          "type": "dose_reduce",
          "components": [
            "docetaxel",
            "carboplatin"
          ],
          "recommendation": "Give 75% docetaxel and carboplatin according to the dose-reduction pathway."
        },
        "source": {
          "page": 5,
          "table": "Table 2"
        },
        "explanation": "ANC 1.0–1.49 with platelets >100 uses 75% doses in the dose-reduction pathway."
      },
      {
        "rule_id": "COUNTS_INTERMEDIATE_GCSF",
        "all": [
          {
            "field": "anc",
            "operator": ">=",
            "value": 1.0
          },
          {
            "field": "anc",
            "operator": "<",
            "value": 1.5
          },
          {
            "field": "platelets",
            "operator": ">",
            "value": 100
          },
          {
            "field": "gcsf_strategy",
            "operator": "==",
            "value": "gcsf"
          }
        ],
        "action": {
          "type": "proceed_with_caution",
          "components": [
            "docetaxel",
            "carboplatin"
          ],
          "recommendation": "The encoded G-CSF option permits 100% regimen with G-CSF support; confirm the selected strategy with the consultant."
        },
        "source": {
          "page": 5,
          "table": "Table 2"
        },
        "explanation": "The source includes a 100% regimen plus G-CSF option."
      },
      {
        "rule_id": "COUNTS_LOW_REDUCE",
        "all": [
          {
            "any": [
              {
                "field": "anc",
                "operator": "<",
                "value": 1.0
              },
              {
                "field": "platelets",
                "operator": "<=",
                "value": 100
              }
            ]
          },
          {
            "field": "gcsf_strategy",
            "operator": "==",
            "value": "dose_reduction"

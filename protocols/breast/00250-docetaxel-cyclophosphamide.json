  "rule_engine": {
    "conflict_policy": "most_restrictive_action_wins",
    "missing_data_policy": "report_unassessed_coverage_gap",
    "actions_ranked_most_to_least_restrictive": [
      "permanently_discontinue",
      "contraindicated",
      "discontinue",
      "cease",
      "omit",
      "withhold_then_reduce",
      "withhold",
      "delay_then_dose_reduce",
      "delay",
      "consultant_review",
      "dose_reduce_two_levels",
      "dose_reduce_one_level",
      "dose_reduce",
      "proceed_with_caution",
      "proceed"
    ],
    "rules": [
      {
        "rule_id": "EXCLUSION_HYPERSENSITIVITY",
        "field": "hypersensitivity",
        "operator": "==",
        "value": true,
        "action": {
          "type": "contraindicated",
          "components": [
            "docetaxel",
            "cyclophosphamide"
          ],
          "recommendation": "Do not administer this regimen; obtain consultant review."
        },
        "source": {
          "page": 2
        },
        "explanation": "Relevant hypersensitivity is an exclusion."
      },
      {
        "rule_id": "EXCLUSION_PREGNANCY_LACTATION",
        "any": [
          {
            "field": "pregnancy",
            "operator": "==",
            "value": true
          },
          {
            "field": "breastfeeding",
            "operator": "==",
            "value": true
          }
        ],
        "action": {
          "type": "contraindicated",
          "components": [
            "docetaxel",
            "cyclophosphamide"
          ],
          "recommendation": "Do not administer; urgent consultant review required."
        },
        "source": {
          "page": 2
        },
        "explanation": "Pregnancy or breastfeeding is an exclusion/caution for this regimen."
      },
      {
        "rule_id": "ACTIVE_INFECTION",
        "field": "active_infection",
        "operator": "==",
        "value": true,
        "action": {
          "type": "withhold",
          "components": [
            "docetaxel",
            "cyclophosphamide"
          ],
          "recommendation": "Withhold and assess/treat infection; discuss with consultant."
        },
        "source": {
          "page": 3
        },
        "explanation": "Clinically significant infection requires review before treatment."
      },
      {
        "rule_id": "ANC_LOW",
        "field": "anc",
        "operator": "<",
        "value": 1.0,
        "action": {
          "type": "delay",
          "components": [
            "docetaxel",
            "cyclophosphamide"
          ],
          "recommendation": "Delay treatment and repeat FBC; discuss dose modification with consultant."
        },
        "source": {
          "page": 4
        },
        "explanation": "ANC below treatment threshold."
      },
      {
        "rule_id": "PLATELETS_LOW",
        "field": "platelets",
        "operator": "<",
        "value": 75,
        "action": {
          "type": "delay",
          "components": [
            "docetaxel",
            "cyclophosphamide"
          ],
          "recommendation": "Delay treatment and repeat FBC; discuss dose modification with consultant."
        },
        "source": {
          "page": 4
        },
        "explanation": "Platelets below treatment threshold."
      },
      {
        "rule_id": "DIARRHOEA_G3PLUS",
        "field": "diarrhoea_grade",
        "operator": ">=",
        "value": 3,
        "action": {
          "type": "withhold_then_reduce",
          "components": [
            "docetaxel",
            "cyclophosphamide"
          ],
          "recommendation": "Withhold until recovery and consider dose reduction according to the NCCP table."
        },
        "source": {
          "page": 5
        },
        "explanation": "Severe diarrhoea requires withholding and dose review."
      },
      {
        "rule_id": "STOMATITIS_G3PLUS",
        "field": "stomatitis_grade",
        "operator": ">=",
        "value": 3,
        "action": {
          "type": "withhold_then_reduce",
          "components": [
            "docetaxel",
            "cyclophosphamide"
          ],
          "recommendation": "Withhold until recovery and consider dose reduction according to the NCCP table."
        },
        "source": {
          "page": 5
        },
        "explanation": "Severe mucositis requires withholding and dose review."
      },
      {
        "rule_id": "DOCETAXEL_NEUROPATHY",
        "field": "neuropathy_grade",
        "operator": ">=",
        "value": 3,
        "action": {
          "type": "withhold_then_reduce",
          "components": [
            "docetaxel"
          ],
          "recommendation": "Withhold docetaxel until improvement and apply NCCP dose modification."
        },
        "source": {
          "page": 4
        },
        "explanation": "Severe neuropathy requires interruption."
      },
      {
        "rule_id": "DOCETAXEL_HEPATIC",
        "any": [
          {
            "field": "bilirubin_uln_multiple",
            "operator": ">",
            "value": 1
          },
          {
            "field": "alt_uln_multiple",
            "operator": ">",
            "value": 3.5
          }
        ],
        "action": {
          "type": "consultant_review",
          "components": [
            "docetaxel"
          ],
          "recommendation": "Do not proceed without consultant/pharmacy review of docetaxel hepatic dosing."
        },
        "source": {
          "page": 3
        },
        "explanation": "Abnormal hepatic function affects docetaxel dosing."
      },
      {
        "rule_id": "CYCLO_RENAL",
        "field": "egfr",
        "operator": "<",
        "value": 10,
        "action": {
          "type": "dose_reduce",
          "components": [
            "cyclophosphamide"
          ],
          "recommendation": "Consider 50% cyclophosphamide dose with pharmacy verification."
        },
        "source": {
          "page": 3
        },
        "explanation": "Severe renal impairment requires dose reduction."
      }
    ]
  },

        ],
        "action": {
          "type": "dose_reduce",
          "components": [
            "zoledronic acid"
          ],
          "recommendation": "Use zoledronic acid 3.3 mg."
        },
        "source": {
          "page": 2
        },
        "explanation": "CrCl 40–49 mL/min: 3.3 mg."
      },
      {
        "rule_id": "CRCL_50_60",
        "all": [
          {
            "field": "crcl",
            "operator": ">=",

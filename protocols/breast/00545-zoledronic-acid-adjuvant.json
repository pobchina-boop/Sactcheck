        "action": {
          "type": "withhold",
          "components": [
            "zoledronic acid"
          ],
          "recommendation": "Correct calcium, magnesium and/or phosphate abnormality before treatment."
        },
        "source": {
          "page": 1
        },
        "explanation": "Electrolyte abnormalities must be corrected before commencing."
      },
      {
        "rule_id": "CRCL_LT30",
        "field": "crcl",
        "operator": "<",
        "value": 30,
        "action": {
          "type": "contraindicated",
          "components": [
            "zoledronic acid"
          ],
          "recommendation": "Zoledronic acid is not recommended when CrCl is <30 mL/min."
        },
        "source": {
          "page": 2
        },
        "explanation": "Severe renal impairment is an exclusion."
      },
      {
        "rule_id": "CRCL_30_39",
        "all": [
          {
            "field": "crcl",
            "operator": ">=",
            "value": 30
          },
          {

          "components": [
            "zoledronic acid"
          ],
          "recommendation": "Use zoledronic acid 3 mg."
        },
        "source": {
          "page": 2
        },
        "explanation": "CrCl 30–39 mL/min: 3 mg."
      },
      {
        "rule_id": "CRCL_40_49",
        "all": [
          {
            "field": "crcl",
            "operator": ">=",
            "value": 40
          },
          {

  "rule_engine": {
    "conflict_policy": "most_restrictive_action_wins",
    "missing_data_policy": "report_unassessed_coverage_gap",
    "actions_ranked_most_to_least_restrictive": [
      "permanently_discontinue",
      "contraindicated",
      "discontinue",
      "cease",
      "omit",
      "withhold_then_reduce",
      "withhold",
      "delay_then_dose_reduce",
      "delay",
      "consultant_review",
      "dose_reduce_two_levels",
      "dose_reduce_one_level",
      "dose_reduce",
      "proceed_with_caution",
      "proceed"
    ],
    "rules": [
      {
        "rule_id": "EXCLUSION_HYPERSENSITIVITY",
        "field": "hypersensitivity",
        "operator": "==",
        "value": true,
        "action": {
          "type": "contraindicated",
          "components": [
            "gemcitabine",
            "carboplatin"
          ],
          "recommendation": "Do not administer this regimen; obtain consultant review."
        },
        "source": {
          "page": 3
        },
        "explanation": "Relevant hypersensitivity is an exclusion."
      },
      {
        "rule_id": "PREGNANCY_LACTATION",
        "field": "pregnancy_or_breastfeeding",
        "operator": "==",
        "value": true,
        "action": {
          "type": "contraindicated",
          "components": [
            "gemcitabine",
            "carboplatin"
          ],
          "recommendation": "Do not administer without urgent consultant review."
        },
        "source": {
          "page": 3
        },
        "explanation": "Pregnancy/breastfeeding requires urgent specialist review."
      },
      {
        "rule_id": "ACTIVE_INFECTION",
        "field": "active_infection",
        "operator": "==",
        "value": true,
        "action": {
          "type": "withhold",
          "components": [
            "gemcitabine",
            "carboplatin"
          ],
          "recommendation": "Withhold treatment and assess/treat the infection."
        },
        "source": {
          "page": 3
        },
        "explanation": "Clinically significant infection requires review."
      },
      {
        "rule_id": "DAY1_COUNTS_LOW",
        "all": [
          {
            "field": "treatment_day",
            "operator": "==",
            "value": "day1"
          },
          {
            "any": [
              {
                "field": "anc",
                "operator": "<",
                "value": 1
              },
              {
                "field": "platelets",
                "operator": "<",
                "value": 100
              }
            ]
          }
        ],
        "action": {
          "type": "delay",
          "components": [
            "gemcitabine",
            "carboplatin"
          ],
          "recommendation": "Delay Day 1 until ANC ≥1.0 and platelets ≥100 ×10⁹/L. After the first such episode or febrile neutropenia, resume both drugs at 80%; after a second episode, resume at 60%."
        },
        "source": {
          "page": 3,
          "table": "Table 1"
        },
        "explanation": "Day 1 proceeds only at ANC ≥1.0 and platelets ≥100."
      },
      {
        "rule_id": "DAY8_OMIT",
        "all": [
          {
            "field": "treatment_day",
            "operator": "==",
            "value": "day8"
          },
          {
            "any": [
              {
                "field": "anc",
                "operator": "<",
                "value": 0.75
              },
              {
                "field": "platelets",
                "operator": "<",
                "value": 75
              }
            ]
          }
        ],
        "action": {
          "type": "omit",
          "components": [
            "gemcitabine",
            "carboplatin"
          ],
          "recommendation": "Omit both Day-8 gemcitabine and carboplatin for ANC <0.75 or platelets <75 ×10⁹/L."
        },
        "source": {
          "page": 4,
          "table": "Table 2"
        },
        "explanation": "Day-8 severe cytopenia requires omission."
      },
      {
        "rule_id": "DAY8_75_PERCENT",
        "all": [
          {
            "field": "treatment_day",
            "operator": "==",
            "value": "day8"
          },
          {
            "any": [
              {
                "all": [
                  {
                    "field": "anc",
                    "operator": ">=",
                    "value": 0.75
                  },
                  {
                    "field": "anc",
                    "operator": "<",
                    "value": 1.0
                  }
                ]
              },
              {
                "all": [
                  {
                    "field": "platelets",
                    "operator": ">=",
                    "value": 75
                  },
                  {
                    "field": "platelets",
                    "operator": "<",
                    "value": 100
                  }
                ]
              }
            ]
          }
        ],
        "action": {
          "type": "dose_reduce",
          "components": [
            "gemcitabine",
            "carboplatin"
          ],
          "recommendation": "Administer both Day-8 drugs at 80% of the Day-1 dose for ANC 0.75–0.99 or platelets 75–99 ×10⁹/L."
        },
        "source": {
          "page": 4,
          "table": "Table 2"
        },
        "explanation": "Day-8 intermediate cytopenia requires 75% dosing."
      },
      {
        "rule_id": "PRIOR_HAEM_EVENT_REDUCE",
        "field": "haematologic_event",
        "operator": "!=",
        "value": "none",
        "action": {
          "type": "dose_reduce",
          "components": [
            "gemcitabine",
            "carboplatin"
          ],
          "recommendation": "After first Day-1 cytopenic delay, febrile neutropenia, platelets <25, or bleeding with thrombocytopenia: resume both drugs at 80% once ANC ≥1.0 and platelets ≥100. After a second episode: resume at 60%."
        },
        "source": {
          "page": 3,
          "table": "Table 1"
        },
        "explanation": "Severe prior-cycle haematologic toxicity requires a subsequent-cycle reduction."
      },
      {
        "rule_id": "CARBOPLATIN_GFR_20_OR_LESS",
        "field": "gfr_ml_min",
        "operator": "<=",
        "value": 20,
        "action": {
          "type": "contraindicated",
          "components": [
            "carboplatin"
          ],
          "recommendation": "Do not administer carboplatin at GFR ≤20 mL/min."
        },
        "source": {
          "page": 5
        },
        "explanation": "Carboplatin should not be administered at GFR ≤20."
      },
      {
        "rule_id": "CARBOPLATIN_GFR_20_TO_30",
        "all": [
          {
            "field": "gfr_ml_min",
            "operator": ">",
            "value": 20
          },
          {
            "field": "gfr_ml_min",
            "operator": "<=",
            "value": 30
          }
        ],
        "action": {
          "type": "consultant_review",
          "components": [
            "carboplatin"
          ],
          "recommendation": "Use carboplatin with extreme caution at GFR 20–30 mL/min; consultant and pharmacy review required."
        },
        "source": {
          "page": 5
        },
        "explanation": "Severe renal impairment requires extreme caution."
      },
      {
        "rule_id": "GEMCITABINE_BILIRUBIN_27_PLUS",
        "field": "bilirubin_micromol_l",
        "operator": ">=",
        "value": 27,
        "action": {
          "type": "consultant_review",
          "components": [
            "gemcitabine"
          ],
          "recommendation": "For bilirubin ≥27 µmol/L, consider starting gemcitabine at 80% with potential escalation, or full dose with active monitoring, after consultant review."
        },
        "source": {
          "page": 5
        },
        "explanation": "Hepatic impairment requires an individualised NCCP option."
      },
      {
        "rule_id": "NONHAEM_G3PLUS",
        "field": "nonhaem_toxicity_grade",
        "operator": ">=",
        "value": 3,
        "action": {
          "type": "withhold_then_reduce",
          "components": [
            "gemcitabine",
            "carboplatin"
          ],
          "recommendation": "Withhold until toxicity recovers to grade 1 or less, then consider a dose reduction."
        },
        "source": {
          "page": 6
        },
        "explanation": "Grade 3 or greater non-haematologic toxicity requires withholding and review."
      },
      {
        "rule_id": "PNEUMONITIS_G2PLUS",
        "field": "pneumonitis_grade",
        "operator": ">=",
        "value": 2,
        "action": {
          "type": "discontinue",
          "components": [
            "gemcitabine"
          ],
          "recommendation": "Discontinue gemcitabine for grade 2 or greater pneumonitis and assess urgently."
        },
        "source": {
          "page": 7
        },
        "explanation": "Clinically significant pneumonitis requires gemcitabine discontinuation."
      },
      {
        "rule_id": "SCAR_CONFIRMED",
        "field": "scar_status",
        "operator": "==",
        "value": "confirmed",
        "action": {
          "type": "permanently_discontinue",
          "components": [
            "gemcitabine"
          ],
          "recommendation": "Permanently discontinue gemcitabine for confirmed SCAR."
        },
        "source": {
          "page": 7
        },
        "explanation": "Confirmed SCAR requires permanent discontinuation."
      },
      {
        "rule_id": "SCAR_SUSPECTED",
        "field": "scar_status",
        "operator": "==",
        "value": "suspected",
        "action": {
          "type": "withhold",
          "components": [
            "gemcitabine"
          ],
          "recommendation": "Withhold gemcitabine while suspected SCAR is urgently evaluated."
        },
        "source": {
          "page": 7
        },
        "explanation": "Suspected SCAR requires immediate withholding and assessment."
      },
      {
        "rule_id": "HAEMODIALYSIS_TIMING",
        "field": "haemodialysis",
        "operator": "==",
        "value": true,
        "action": {
          "type": "consultant_review",
          "components": [
            "gemcitabine"
          ],
          "recommendation": "Confirm gemcitabine and dialysis timing with oncology pharmacy; NCCP notes dialysis 6–12 hours after gemcitabine."
        },
        "source": {
          "page": 5
        },
        "explanation": "Haemodialysis timing requires pharmacy confirmation."
      }
    ]
  },
  "output_templates": {
    "proceed": "No encoded hold, discontinuation, or modification criterion was triggered by the entered data.",
    "coverage_gap": "One or more optional clinical domains were not assessed. Missing values have not been interpreted as normal."
  }
}

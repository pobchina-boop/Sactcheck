          "components": [
            "whole_regimen"
          ]
        },
        "source": {
          "page": 3
        },
        "explanation": "ANC below 1.0 ×10⁹/L or platelets below 100 ×10⁹/L triggers a one-week delay."
      },
      {
        "rule_id": "COUNTS_PROCEED",
        "all": [
          {
            "field": "anc_x10e9_l",
            "operator": ">=",
            "value": 1.0
          },
          {
            "field": "platelets_x10e9_l",
            "operator": ">=",
            "value": 100
          }
        ],
        "action": {
          "type": "proceed",
          "components": [
            "whole_regimen"
          ]
        },
        "source": {
          "page": 3
        },
        "explanation": "Counts meet the encoded day-1 threshold."
      },
      {
        "rule_id": "FEBRILE_NEUTROPENIA_REVIEW",
        "any": [
          {
            "field": "febrile_neutropenia",
            "operator": "==",
            "value": true
          }
        ],
        "action": {
          "type": "dose_reduce",
          "components": [
            "whole_regimen"
          ]
        },
        "source": {
          "page": 3
        },
        "explanation": "Febrile neutropenia triggers dose reduction and/or G-CSF support."
      },
      {
        "rule_id": "NEUROPATHY_REVIEW",
        "any": [
          {
            "field": "neuropathy_grade",
            "operator": ">=",
            "value": 2
          }
        ],
        "action": {
          "type": "consultant_review",
          "components": [
            "whole_regimen"
          ]
        },
        "source": {
          "page": 3
        },
        "explanation": "Paclitaxel-related neuropathy requires review and possible dose modification."
      }
    ]

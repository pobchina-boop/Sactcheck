    ],
    "rules": [
      {
        "rule_id": "EXCLUSION_HYPERSENSITIVITY",
        "field": "relevant_drug_hypersensitivity",
        "operator": "==",
        "value": true,
        "action": {
          "type": "contraindicated",
          "components": [
            "trastuzumab"
          ],
          "recommendation": "Do not administer; obtain consultant review."
        },
        "source": {
          "page": 2
        },
        "explanation": "Relevant hypersensitivity is an exclusion."
      },
      {
        "rule_id": "EXCLUSION_PREGNANCY_BREASTFEEDING",
        "any": [
          {
            "field": "pregnancy",
            "operator": "==",
            "value": true
          },
          {
            "field": "breastfeeding",
            "operator": "==",
            "value": true
          }
        ],
        "action": {
          "type": "contraindicated",
          "components": [
            "trastuzumab"
          ],
          "recommendation": "Do not administer during pregnancy or breastfeeding; urgent consultant review required."
        },
        "source": {
          "page": 2
        },
        "explanation": "Pregnancy and breastfeeding are exclusions."
      },
      {
        "rule_id": "CARDIAC_DISEASE_EXCLUSION",
        "field": "clinically_significant_cardiac_disease",
        "operator": "==",
        "value": true,
        "action": {
          "type": "contraindicated",
          "components": [
            "trastuzumab"
          ],
          "recommendation": "Do not proceed without consultant/cardiology review."
        },
        "source": {
          "page": 2
        },
        "explanation": "Clinically significant cardiac disease is an exclusion."
      },
      {
        "rule_id": "LVEF_WITHHOLD",
        "all": [
          {
            "field": "lvef_percent",
            "operator": "<",
            "value": 50
          },
          {
            "field": "lvef_drop_points",
            "operator": ">=",
            "value": 10
          }
        ],
        "action": {
          "type": "withhold",
          "components": [
            "trastuzumab"
          ],
          "recommendation": "Withhold trastuzumab and repeat LVEF after approximately 3 weeks. If no improvement or further decline, consider discontinuation and refer to cardiology."
        },
        "source": {
          "page": 3
        },
        "explanation": "LVEF fall ≥10 points from baseline and to below 50% requires withholding."
      },
      {
        "rule_id": "SYMPTOMATIC_HEART_FAILURE",
        "field": "symptomatic_heart_failure",
        "operator": "==",
        "value": true,
        "action": {
          "type": "discontinue",
          "components": [
            "trastuzumab"
          ],
          "recommendation": "Consider discontinuation and refer urgently to cardiology."
        },
        "source": {
          "page": 3
        },
        "explanation": "Symptomatic heart failure requires consultant/cardiology review and possible discontinuation."
      },
      {
        "rule_id": "HYPERSENSITIVITY_G4",
        "field": "hypersensitivity_grade",
        "operator": ">=",
        "value": 4,
        "action": {
          "type": "discontinue",
          "components": [
            "trastuzumab"
          ],
          "recommendation": "Permanently discontinue for Grade 4 hypersensitivity."
        },
        "source": {
          "page": 3
        },
        "explanation": "Grade 4 hypersensitivity requires discontinuation."
      },
      {
        "rule_id": "FBC_CLINICAL_REVIEW",
        "field": "fbc_clinical_concern",
        "operator": "==",
        "value": true,
        "action": {
          "type": "consultant_review",
          "components": [
            "trastuzumab"
          ],
          "recommendation": "Review clinically. Trastuzumab may continue during reversible chemotherapy-induced myelosuppression with careful monitoring."
        },
        "source": {
          "page": 3
        },
        "explanation": "No numerical trastuzumab-specific cytopenia threshold is specified."
      }
    ]
  },

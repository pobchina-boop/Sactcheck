        "rule_id": "STOMATITIS_PERSISTENT_TWO_WEEKS",
        "all": [
          {
            "field": "stomatitis_current_grade",
            "operator": ">=",
            "value": 2
          },
          {
            "field": "stomatitis_duration_weeks",
            "operator": ">=",
            "value": 2
          }
        ],
        "action": {
          "type": "discontinue",
          "components": [
            "whole_regimen"
          ],
          "whole_regimen": "discontinue"
        },
        "source": {
          "page": 6,
          "table": 6
        },
        "explanation": "Stomatitis remains grade 2 or greater after two weeks; discontinue treatment."
      },
      {
        "rule_id": "STOMATITIS_HOLD",
        "all": [
          {
            "field": "stomatitis_current_grade",
            "operator": ">=",
            "value": 2
          },
          {
            "field": "stomatitis_duration_weeks",
            "operator": "<",
            "value": 2
          }
        ],
        "action": {
          "type": "withhold",
          "components": [
            "whole_regimen"
          ],
          "whole_regimen": "hold",
          "maximum_delay_weeks": 2
        },
        "source": {
          "page": 6,
          "table": 6
        },
        "explanation": "Grade 2 or greater stomatitis on day 1 requires the complete regimen to be held and reviewed weekly."
      },
      {
        "rule_id": "STOMATITIS_RECOVERED_GRADE3",
        "all": [
          {
            "field": "stomatitis_current_grade",
            "operator": "<",
            "value": 2
          },
          {
            "field": "stomatitis_highest_grade",
            "operator": "==",
            "value": 3
          }
        ],
        "action": {
          "type": "dose_reduce",
          "components": [
            "bolus_5fu",
            "infusional_5fu"
          ],
          "component_changes": {
            "bolus_5fu": {
              "dose_level_change": -1
            },
            "infusional_5fu": {
              "dose_level_change": -1
            }
          }
        },
        "source": {
          "page": 6,
          "table": 6
        },
        "explanation": "After recovery from grade 3 stomatitis, reduce bolus and infusional 5-FU by one dose level."
      },
      {
        "rule_id": "STOMATITIS_RECOVERED_GRADE4",
        "all": [
          {
            "field": "stomatitis_current_grade",
            "operator": "<",
            "value": 2
          },
          {
            "field": "stomatitis_highest_grade",
            "operator": ">=",
            "value": 4
          }
        ],
        "action": {
          "type": "dose_reduce",
          "components": [
            "oxaliplatin",
            "bolus_5fu",
            "infusional_5fu"
          ],
          "component_changes": {
            "oxaliplatin": {
              "dose_level_change": -1
            },
            "bolus_5fu": {
              "dose_level_change": -1
            },
            "infusional_5fu": {
              "dose_level_change": -1
            }
          }
        },
        "source": {
          "page": 6,
          "table": 6
        },
        "explanation": "After recovery from grade 4 stomatitis, reduce oxaliplatin, bolus 5-FU and infusional 5-FU by one dose level."
      },
      {
        "rule_id": "SIGNIFICANT_PPE",
        "field": "significant_ppe",
        "operator": "==",
        "value": true,
        "action": {
          "type": "consultant_review",
          "components": [

      },
      {
        "rule_id": "STOMATITIS_G3_4",
        "field": "stomatitis_highest_grade",
        "operator": ">=",
        "value": 3,
        "action": {
          "type": "dose_reduce",
          "components": [
            "fluorouracil_bolus",
            "fluorouracil_infusion"
          ],

          "components": [
            "whole_regimen"
          ],
          "recommendation": "Hold and repeat FBC weekly for up to 2 weeks."
        },
        "source": {
          "page": 3
        },
        "explanation": "Platelets <75 require hold."
      },
      {
        "rule_id": "PLT_PERSISTENT",
        "all": [
          {
            "field": "platelets_x10e9_l",
            "operator": "<",
            "value": 75
          },
          {
            "field": "toxicity_delay_weeks",

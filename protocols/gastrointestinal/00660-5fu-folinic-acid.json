          "components": [
            "whole_regimen"
          ],
          "recommendation": "Hold and repeat FBC weekly for up to 2 weeks."
        },
        "source": {
          "page": 3
        },
        "explanation": "ANC <1.0 requires hold."
      },
      {
        "rule_id": "ANC_PERSISTENT",

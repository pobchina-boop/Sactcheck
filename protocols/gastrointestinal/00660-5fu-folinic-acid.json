        "action": {
          "type": "dose_reduce",
          "components": [
            "fluorouracil"
          ],
          "recommendation": "Reduce initial fluorouracil dose by one third."
        },
        "source": {
          "page": 4
        },
        "explanation": "Moderate hepatic impairment."
      },
      {
        "rule_id": "HEPATIC_SEVERE",
        "field": "hepatic_impairment_severity",
        "operator": "==",
        "value": "severe",
        "action": {
          "type": "dose_reduce",
          "components": [

        "source": {
          "page": 4
        },
        "explanation": "Severe hepatic impairment."
      },
      {
        "rule_id": "PROCEED",
        "all": [
          {
            "field": "dpd_status",
            "operator": "==",
            "value": "documented_normal"
          },
          {
            "field": "anc_x10e9_l",
            "operator": ">=",
            "value": 1
          },
          {
            "field": "platelets_x10e9_l",
            "operator": ">=",
            "value": 75
          },
          {
            "field": "diarrhoea_current_grade",
            "operator": "<",
            "value": 2
          },
          {
            "field": "stomatitis_current_grade",
            "operator": "<",
            "value": 2
          },
          {
            "field": "hepatic_impairment_severity",
            "operator": "==",
            "value": "none"
          }
        ],
        "action": {
          "type": "proceed",
          "components": [
            "whole_regimen"
          ],
          "recommendation": "No encoded modification triggered."
        },
        "source": {
          "page": 3
        },

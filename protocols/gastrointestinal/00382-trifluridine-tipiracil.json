  "rule_engine": {
    "conflict_policy": "Use the most restrictive overall action; combine component changes using the greatest reduction per component rather than summing reductions.",
    "missing_data_policy": "Do not infer missing clinical values.",
    "actions_ranked_most_to_least_restrictive": [
      "contraindicated",
      "discontinue",
      "withhold",
      "consultant_review",
      "dose_reduce",
      "proceed"
    ],
    "rules": [
      {
        "rule_id": "EXCLUSION_HYPERSENSITIVITY",
        "field": "hypersensitivity",
        "operator": "==",
        "value": true,
        "action": {
          "type": "contraindicated",
          "components": [
            "lonsurf"
          ],
          "recommendation": "Do not administer."
        },
        "source": {
          "page": 2
        },
        "explanation": "Hypersensitivity is an exclusion."
      },
      {
        "rule_id": "PREG_LACT",
        "any": [
          {
            "field": "pregnancy",
            "operator": "==",
            "value": true
          },
          {
            "field": "breastfeeding",
            "operator": "==",
            "value": true
          }
        ],
        "action": {
          "type": "contraindicated",
          "components": [
            "lonsurf"
          ],
          "recommendation": "Do not administer."
        },
        "source": {
          "page": 2
        },
        "explanation": "Pregnancy or lactation is an exclusion."
      },
      {
        "rule_id": "ANC_INTERRUPT",
        "field": "anc_x10e9_l",
        "operator": "<",
        "value": 0.5,
        "action": {
          "type": "withhold",
          "components": [
            "lonsurf"
          ],
          "recommendation": "Interrupt until ANC ≥1.5 ×10⁹/L."
        },
        "source": {
          "page": 2
        },
        "explanation": "ANC interruption threshold."
      },
      {
        "rule_id": "PLT_INTERRUPT",
        "field": "platelets_x10e9_l",
        "operator": "<",
        "value": 50,
        "action": {
          "type": "withhold",
          "components": [
            "lonsurf"
          ],
          "recommendation": "Interrupt until platelets ≥75 ×10⁹/L."
        },
        "source": {
          "page": 2
        },
        "explanation": "Platelet interruption threshold."
      },
      {
        "rule_id": "ANC_NEXT_CYCLE",
        "all": [
          {
            "field": "anc_x10e9_l",
            "operator": ">=",
            "value": 0.5
          },
          {
            "field": "anc_x10e9_l",
            "operator": "<",
            "value": 1.5
          }
        ],
        "action": {
          "type": "withhold",
          "components": [
            "lonsurf"
          ],
          "recommendation": "Do not start the next cycle until ANC ≥1.5 ×10⁹/L."
        },
        "source": {
          "page": 2
        },
        "explanation": "Next-cycle ANC resumption criterion."
      },
      {
        "rule_id": "PLT_NEXT_CYCLE",
        "all": [
          {
            "field": "platelets_x10e9_l",
            "operator": ">=",
            "value": 50
          },
          {
            "field": "platelets_x10e9_l",
            "operator": "<",
            "value": 75
          }
        ],
        "action": {
          "type": "withhold",
          "components": [
            "lonsurf"
          ],
          "recommendation": "Do not start the next cycle until platelets ≥75 ×10⁹/L."
        },
        "source": {
          "page": 2
        },
        "explanation": "Next-cycle platelet resumption criterion."
      },
      {
        "rule_id": "SEVERE_TOX_REDUCE",
        "any": [
          {
            "field": "febrile_neutropenia",
            "operator": "==",
            "value": true
          },
          {
            "field": "grade4_neutropenia",
            "operator": "==",
            "value": true
          },
          {
            "field": "grade4_thrombocytopenia",
            "operator": "==",
            "value": true
          },
          {
            "field": "toxicity_requiring_interruption",
            "operator": "==",
            "value": true
          }
        ],
        "action": {
          "type": "withhold_then_reduce",
          "components": [
            "lonsurf"
          ],
          "recommendation": "After recovery, reduce by 5 mg/m² per dose; maximum three reductions, minimum 20 mg/m² BD (or 15 mg/m² in severe renal impairment)."
        },
        "source": {
          "page": 3
        },
        "explanation": "Severe toxicity triggers interruption and dose reduction."
      },
      {
        "rule_id": "RENAL_15_29",
        "all": [
          {
            "field": "crcl_ml_min",
            "operator": ">=",
            "value": 15
          },
          {
            "field": "crcl_ml_min",
            "operator": "<",
            "value": 30
          }
        ],
        "action": {
          "type": "dose_reduce",
          "components": [
            "lonsurf"
          ],
          "recommendation": "Use a starting dose of 20 mg/m² twice daily; one reduction to 15 mg/m² is permitted."
        },
        "source": {
          "page": 4
        },
        "explanation": "Severe renal impairment dosing."
      },
      {
        "rule_id": "RENAL_LT15",
        "any": [
          {
            "field": "crcl_ml_min",
            "operator": "<",
            "value": 15
          },
          {
            "field": "dialysis",
            "operator": "==",
            "value": true
          }
        ],
        "action": {
          "type": "contraindicated",
          "components": [
            "lonsurf"
          ],
          "recommendation": "Administration is not recommended."
        },
        "source": {
          "page": 4
        },
        "explanation": "End-stage renal disease/dialysis is not recommended."
      },
      {
        "rule_id": "HEPATIC_MOD_SEV",
        "any": [
          {
            "field": "hepatic_impairment",
            "operator": "in",
            "value": [
              "moderate",
              "severe"
            ]
          },
          {
            "field": "bilirubin_ratio_uln",
            "operator": ">",
            "value": 1.5
          }
        ],
        "action": {
          "type": "contraindicated",
          "components": [
            "lonsurf"
          ],
          "recommendation": "Administration is not recommended at baseline."
        },
        "source": {
          "page": 4
        },
        "explanation": "Moderate/severe hepatic impairment is not recommended."
      },
      {
        "rule_id": "PROCEED",
        "all": [
          {
            "field": "hypersensitivity",
            "operator": "==",
            "value": false
          },
          {
            "field": "pregnancy",
            "operator": "==",
            "value": false
          },
          {
            "field": "breastfeeding",
            "operator": "==",
            "value": false
          },
          {
            "field": "anc_x10e9_l",
            "operator": ">=",
            "value": 1.5
          },
          {
            "field": "platelets_x10e9_l",
            "operator": ">=",
            "value": 75
          },
          {
            "field": "crcl_ml_min",
            "operator": ">=",
            "value": 30
          },
          {
            "field": "bilirubin_ratio_uln",
            "operator": "<=",
            "value": 1.5
          },
          {
            "field": "hepatic_impairment",
            "operator": "in",
            "value": [
              "none",
              "mild"
            ]
          }
        ],
        "action": {
          "type": "proceed",
          "components": [
            "whole_regimen"
          ],
          "recommendation": "No encoded modification triggered."
        },
        "source": {
          "page": 3
        },
        "explanation": "Entered values meet encoded next-cycle criteria."
      }
    ]
  },

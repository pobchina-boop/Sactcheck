  "output_templates": {
    "contraindicated": "The entered data trigger a protocol exclusion or contraindication pathway.",
    "discontinue": "The entered data trigger protocol discontinuation.",
    "withhold": "Hold treatment and follow the protocol reassessment pathway.",
    "consultant_review": "Consultant review is required before treatment proceeds.",
    "dose_reduce": "Treatment may proceed only after the encoded component modifications are reviewed and prescribed.",

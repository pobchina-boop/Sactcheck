  "rule_engine": {
    "conflict_policy": "Use the most restrictive overall action; combine component changes using the greatest reduction per component rather than summing reductions.",
    "missing_data_policy": "Do not infer missing clinical values.",
    "actions_ranked_most_to_least_restrictive": [
      "contraindicated",
      "discontinue",
      "withhold",
      "consultant_review",
      "dose_reduce",
      "proceed"
    ],
    "rules": [
      {
        "rule_id": "BASELINE_NEUTROPHILS",
        "field": "baseline_neutrophils_x10e9_l",
        "operator": "<",
        "value": 2,
        "action": {
          "type": "contraindicated",
          "components": [
            "whole_regimen"
          ],
          "recommendation": "Do not initiate FOLFOXIRI."
        },
        "source": {
          "page": 2
        },
        "explanation": "Baseline neutrophils <2 are an exclusion."
      },
      {
        "rule_id": "BASELINE_PLATELETS",
        "field": "baseline_platelets_x10e9_l",
        "operator": "<",
        "value": 100,
        "action": {
          "type": "contraindicated",
          "components": [
            "whole_regimen"
          ],
          "recommendation": "Do not initiate FOLFOXIRI."
        },
        "source": {
          "page": 2
        },
        "explanation": "Baseline platelets <100 are an exclusion."
      },
      {
        "rule_id": "CRCL_LT30",
        "field": "crcl_ml_min",
        "operator": "<",
        "value": 30,
        "action": {
          "type": "contraindicated",
          "components": [
            "oxaliplatin",
            "whole_regimen"
          ],
          "recommendation": "Severe renal impairment is an exclusion."
        },
        "source": {
          "page": 2
        },
        "explanation": "CrCl <30 is excluded."
      },
      {
        "rule_id": "BILI_GT3",
        "field": "bilirubin_ratio_uln",
        "operator": ">",
        "value": 3,
        "action": {
          "type": "contraindicated",
          "components": [
            "irinotecan",
            "whole_regimen"
          ],
          "recommendation": "Do not administer irinotecan/FOLFOXIRI."
        },
        "source": {
          "page": 2
        },
        "explanation": "Bilirubin >3\u00d7ULN is an exclusion."
      },
      {
        "rule_id": "DPD_COMPLETE",
        "field": "dpd_status",
        "operator": "==",
        "value": "complete",
        "action": {
          "type": "contraindicated",
          "components": [
            "fluorouracil",
            "whole_regimen"
          ],
          "recommendation": "Do not administer fluorouracil."
        },
        "source": {
          "page": 2
        },
        "explanation": "Complete DPD deficiency."
      },
      {
        "rule_id": "ANC_DAY1",
        "field": "anc_x10e9_l",
        "operator": "<",
        "value": 1.5,
        "action": {
          "type": "withhold",
          "components": [
            "whole_regimen"
          ],
          "recommendation": "Delay 1\u20132 weeks; occurrence-based component reductions apply after recovery."
        },
        "source": {
          "page": 3
        },
        "explanation": "ANC below 1.5 requires delay."
      },
      {
        "rule_id": "PLT_DAY1",
        "field": "platelets_x10e9_l",
        "operator": "<",
        "value": 75,
        "action": {
          "type": "withhold",
          "components": [
            "whole_regimen"
          ],
          "recommendation": "Delay 1\u20132 weeks; occurrence-based component reductions apply after recovery."
        },
        "source": {
          "page": 3
        },
        "explanation": "Platelets below 75 require delay."
      },
      {
        "rule_id": "DELAY_2W",
        "all": [
          {
            "field": "toxicity_delay_weeks",
            "operator": ">=",
            "value": 2
          },
          {
            "any": [
              {
                "field": "anc_x10e9_l",
                "operator": "<",
                "value": 1.5
              },
              {
                "field": "platelets_x10e9_l",
                "operator": "<",
                "value": 75
              }
            ]
          }
        ],
        "action": {
          "type": "consultant_review",
          "components": [
            "whole_regimen"
          ],
          "recommendation": "Consider discontinuation if counts have not recovered within 2 weeks."
        },
        "source": {
          "page": 3
        },
        "explanation": "No recovery after 2 weeks requires discontinuation consideration."
      },
      {
        "rule_id": "DIARRHOEA_G3PLUS",
        "field": "diarrhoea_highest_grade",
        "operator": ">=",
        "value": 3,
        "action": {
          "type": "dose_reduce",
          "components": [
            "irinotecan",
            "fluorouracil"
          ],
          "recommendation": "Reduce irinotecan and fluorouracil according to occurrence table."
        },
        "source": {
          "page": 4
        },
        "explanation": "Grade 3\u20134 diarrhoea triggers reductions."
      },
      {
        "rule_id": "MUCOSITIS_G3PLUS",
        "field": "stomatitis_highest_grade",
        "operator": ">=",
        "value": 3,
        "action": {
          "type": "dose_reduce",
          "components": [
            "fluorouracil"
          ],
          "recommendation": "Reduce fluorouracil to 75% for grade 3\u20134 mucositis/HFS."
        },
        "source": {
          "page": 4
        },
        "explanation": "Severe mucositis requires fluorouracil reduction."
      },
      {
        "rule_id": "NEUROPATHY_G2_PERSIST",
        "field": "neuropathy_grade",
        "operator": ">=",
        "value": 2,
        "action": {
          "type": "consultant_review",
          "components": [
            "oxaliplatin"
          ],
          "recommendation": "For persistent grade 2 or transient grade 3 symptoms, reduce oxaliplatin; discontinue for persistent grade 3/grade 4."
        },
        "source": {
          "page": 4
        },
        "explanation": "Neuropathy requires oxaliplatin modification."
      },
      {
        "rule_id": "LPD",
        "field": "laryngopharyngeal_dysaesthesia",
        "operator": "==",
        "value": true,
        "action": {
          "type": "consultant_review",
          "components": [
            "oxaliplatin"
          ],
          "recommendation": "Increase oxaliplatin infusion time from 2 to 6 hours."
        },
        "source": {
          "page": 4
        },
        "explanation": "Laryngopharyngeal dysaesthesia requires prolonged infusion."
      },
      {
        "rule_id": "CHOLINERGIC",
        "field": "acute_cholinergic_syndrome",
        "operator": "==",
        "value": true,
        "action": {
          "type": "consultant_review",
          "components": [
            "irinotecan"
          ],
          "recommendation": "Administer atropine 250 micrograms SC unless contraindicated; consider prophylaxis subsequently."
        },
        "source": {
          "page": 5
        },
        "explanation": "Acute cholinergic syndrome management."
      },
      {
        "rule_id": "PROCEED",
        "all": [
          {
            "field": "baseline_neutrophils_x10e9_l",
            "operator": ">=",
            "value": 2
          },
          {
            "field": "baseline_platelets_x10e9_l",
            "operator": ">=",
            "value": 100
          },
          {
            "field": "anc_x10e9_l",
            "operator": ">=",
            "value": 1.5
          },
          {
            "field": "platelets_x10e9_l",
            "operator": ">=",
            "value": 75
          },
          {
            "field": "crcl_ml_min",
            "operator": ">=",
            "value": 30
          },
          {
            "field": "bilirubin_ratio_uln",
            "operator": "<=",
            "value": 3
          },
          {
            "field": "dpd_status",
            "operator": "==",
            "value": "documented_normal"
          },
          {
            "field": "diarrhoea_current_grade",
            "operator": "<",
            "value": 2
          },
          {
            "field": "neuropathy_grade",
            "operator": "<",
            "value": 2
          }
        ],
        "action": {
          "type": "proceed",
          "components": [
            "whole_regimen"
          ],
          "recommendation": "No encoded modification triggered."
        },
        "source": {
          "page": 3
        },
        "explanation": "Entered values meet encoded parameters."
      }
    ]
  },

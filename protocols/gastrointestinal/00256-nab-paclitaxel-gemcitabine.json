  "rule_engine": {
    "conflict_policy": "most_restrictive_action_wins",
    "missing_data_policy": "Evaluate only supplied values; do not infer missing values. Eligibility/context fields remain optional unless a specific rule requires them.",
    "actions_ranked_most_to_least_restrictive": [
      "permanently_discontinue",
      "contraindicated",
      "discontinue",
      "cease",
      "omit",
      "withhold_then_reduce",
      "withhold",
      "delay_then_dose_reduce",
      "delay",
      "consultant_review",
      "dose_reduce_two_levels",
      "dose_reduce_one_level",
      "dose_reduce",
      "proceed_with_caution",
      "proceed"
    ],
    "rules": [
      {
        "rule_id": "DAY1_COUNTS",
        "any": [
          {
            "field": "anc",
            "operator": "<",
            "value": 1.5
          },
          {
            "field": "platelets",
            "operator": "<",
            "value": 100
          }
        ],
        "action": {
          "type": "withhold",
          "components": [
            "whole_regimen"
          ],
          "recommendation": "Delay Day 1 doses until count recovery."
        },
        "source": {
          "page": 3
        },
        "explanation": "Day 1 ANC <1.5 or platelets <100 requires delay."
      },
      {
        "rule_id": "DAY8_LOW",
        "all": [
          {
            "field": "assessment_day",
            "operator": "==",
            "value": 8
          }
        ],
        "any": [
          {
            "field": "anc",
            "operator": "<",
            "value": 0.5
          },
          {
            "field": "platelets",
            "operator": "<",
            "value": 50
          }
        ],
        "action": {
          "type": "withhold",
          "components": [
            "whole_regimen"
          ],
          "recommendation": "Withhold Day 8 doses."
        },
        "source": {
          "page": 3
        },
        "explanation": "Day 8 ANC <0.5 or platelets <50 requires withholding."
      },
      {
        "rule_id": "DAY8_INTERMEDIATE",
        "all": [
          {
            "field": "assessment_day",
            "operator": "==",
            "value": 8
          },
          {
            "field": "anc",
            "operator": ">=",
            "value": 0.5
          },
          {
            "field": "anc",
            "operator": "<",
            "value": 1
          }
        ],
        "action": {
          "type": "dose_reduce",
          "components": [
            "nab-paclitaxel",
            "gemcitabine"
          ],
          "recommendation": "Reduce both drugs by one dose level."
        },
        "source": {
          "page": 3
        },
        "explanation": "Day 8 intermediate neutropenia requires one-level reduction."
      },
      {
        "rule_id": "NEUROPATHY_G3",
        "field": "neuropathy_grade",
        "operator": ">=",
        "value": 3,
        "action": {
          "type": "withhold",
          "components": [
            "nab-paclitaxel"
          ],
          "recommendation": "Withhold nab-paclitaxel until neuropathy improves to grade 1 or less, then resume one level lower."
        },
        "source": {
          "page": 5
        },
        "explanation": "Withhold nab-paclitaxel until neuropathy improves to grade 1 or less, then resume one level lower."
      },
      {
        "rule_id": "FN_G3",
        "field": "febrile_neutropenia_grade",
        "operator": ">=",
        "value": 3,
        "action": {
          "type": "withhold",
          "components": [
            "whole_regimen"
          ],
          "recommendation": "Withhold until fever resolves and ANC ≥1.5, then resume at the next lower dose level."
        },
        "source": {
          "page": 5
        },
        "explanation": "Withhold until fever resolves and ANC ≥1.5, then resume at the next lower dose level."
      },
      {
        "rule_id": "PNEUMONITIS",
        "field": "pneumonitis",
        "operator": "==",
        "value": true,
        "action": {
          "type": "discontinue",
          "components": [
            "whole_regimen"
          ],
          "recommendation": "Discontinue treatment for pneumonitis."
        },
        "source": {
          "page": 5
        },
        "explanation": "Discontinue treatment for pneumonitis."
      },
      {
        "rule_id": "HUS",
        "field": "hus",
        "operator": "==",
        "value": true,
        "action": {
          "type": "discontinue",
          "components": [
            "whole_regimen"
          ],
          "recommendation": "Discontinue treatment for haemolytic uraemic syndrome."
        },
        "source": {
          "page": 5
        },
        "explanation": "Discontinue treatment for haemolytic uraemic syndrome."
      },
      {
        "rule_id": "SCAR",
        "field": "scar",
        "operator": "==",
        "value": true,
        "action": {
          "type": "discontinue",
          "components": [
            "gemcitabine"
          ],
          "recommendation": "Discontinue gemcitabine for a severe cutaneous adverse reaction."
        },
        "source": {
          "page": 5
        },
        "explanation": "Discontinue gemcitabine for a severe cutaneous adverse reaction."
      }
    ]
  },

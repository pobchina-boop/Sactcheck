      {
        "rule_id": "HTN_G3",
        "field": "hypertension_grade",
        "operator": ">=",
        "value": 3,
        "action": {
          "type": "withhold",
          "components": [
            "regorafenib"
          ],
          "recommendation": "Hold and intensify antihypertensive treatment; dose reduction may be required."
        },
        "source": {
          "page": 5
        },
        "explanation": "Grade 3 hypertension requires hold."
      },
      {
        "rule_id": "PROCEED",
        "all": [
          {
            "field": "child_pugh",
            "operator": "in",
            "value": [
              "none",
              "A",
              "B"
            ]
          },
          {
            "field": "hfsr_grade",
            "operator": "<",
            "value": 2
          },
          {
            "field": "alt_ast_ratio_uln",
            "operator": "<=",
            "value": 5
          },
          {
            "field": "hypertension_grade",
            "operator": "<",
            "value": 2
          },
          {
            "field": "other_toxicity_grade",
            "operator": "<",
            "value": 3
          }
        ],
        "action": {
          "type": "proceed",

                "value": true
              },
              {
                "field": "hfsr_occurrence",
                "operator": ">=",
                "value": 2
              }
            ]
          }
        ],
        "action": {
          "type": "withhold_then_reduce",
          "components": [
            "regorafenib"
          ],
          "recommendation": "Interrupt until grade 0\u20131, then restart 40 mg lower."
        },
        "source": {
          "page": 3
        },
        "explanation": "Persistent/recurrent grade 2 HFSR."
      },
      {
        "rule_id": "HFSR_G2_FOURTH",
        "all": [
          {
            "field": "hfsr_grade",
            "operator": "==",
            "value": 2
          },
          {

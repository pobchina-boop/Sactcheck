            "operator": ">=",
            "value": 4
          }
        ],
        "action": {
          "type": "discontinue",
          "components": [
            "regorafenib"
          ],
          "recommendation": "Discontinue permanently."
        },
        "source": {
          "page": 3
        },
        "explanation": "Fourth grade 2 HFSR occurrence."
      },
      {
        "rule_id": "HFSR_G3",
        "all": [
          {
            "field": "hfsr_grade",
            "operator": "==",
            "value": 3
          },
          {
            "field": "hfsr_occurrence",
            "operator": "<",
            "value": 3
          }
        ],
        "action": {
          "type": "withhold_then_reduce",
          "components": [
            "regorafenib"
          ],
          "recommendation": "Interrupt at least 7 days until grade 0\u20131, then restart 40 mg lower."
        },
        "source": {
          "page": 3
        },
        "explanation": "Grade 3 HFSR requires interruption and reduction."
      },
      {
        "rule_id": "HFSR_G3_THIRD",
        "all": [
          {
            "field": "hfsr_grade",
            "operator": "==",
            "value": 3
          },

            "operator": "<=",
            "value": 1
          },
          {
            "field": "hfsr_no_improvement_7_days",
            "operator": "==",
            "value": false
          }
        ],
        "action": {
          "type": "dose_reduce",
          "components": [
            "regorafenib"
          ],
          "recommendation": "Decrease dose by 40 mg and institute supportive measures."
        },
        "source": {
          "page": 3
        },
        "explanation": "First grade 2 HFSR requires a 40 mg reduction."
      },
      {
        "rule_id": "HFSR_G2_PERSIST",

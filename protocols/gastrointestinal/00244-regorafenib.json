          ],
          "recommendation": "Discontinue permanently and monitor weekly."
        },
        "source": {
          "page": 4
        },
        "explanation": "Transaminases >3\u00d7ULN with bilirubin >2\u00d7ULN."
      },
      {
        "rule_id": "HTN_G2_SYMPTOMATIC",
        "all": [
          {

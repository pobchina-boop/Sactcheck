          "components": [
            "regorafenib"
          ],
          "recommendation": "Regorafenib is not recommended."
        },
        "source": {
          "page": 3
        },
        "explanation": "Severe hepatic impairment is not recommended."
      },
      {
        "rule_id": "HFSR_G2_FIRST",
        "all": [
          {
            "field": "hfsr_grade",
            "operator": "==",
            "value": 2
          },
          {

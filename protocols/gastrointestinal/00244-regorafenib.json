          ],
          "recommendation": "Discontinue permanently."
        },
        "source": {
          "page": 4
        },
        "explanation": "Recurrent grade 3 transaminase elevation."
      },
      {
        "rule_id": "LIVER_G4",
        "field": "alt_ast_ratio_uln",
        "operator": ">",
        "value": 20,
        "action": {
          "type": "discontinue",
          "components": [
            "regorafenib"
          ],
          "recommendation": "Discontinue permanently."
        },
        "source": {
          "page": 4
        },
        "explanation": "Grade 4 transaminase elevation."
      },
      {
        "rule_id": "LIVER_HY",
        "all": [

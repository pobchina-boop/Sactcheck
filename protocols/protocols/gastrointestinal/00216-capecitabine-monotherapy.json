          },
          {
            "field": "crcl_ml_min",
            "operator": ">",
            "value": 50
          },
          {
            "field": "diarrhoea_current_grade",
            "operator": "<",
            "value": 2
          },
          {
            "field": "hand_foot_grade",
            "operator": "<",
            "value": 2
          },
          {

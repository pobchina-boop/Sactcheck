        "action": {
          "type": "consultant_review",
          "components": [
            "cisplatin"
          ],
          "recommendation": "Review cisplatin due to neuropathy; dose modification or substitution may be required."
        },
        "source": {
          "page": 5
        },
        "explanation": "Cisplatin neurotoxicity requires review."
      }

  "rule_engine": {
    "conflict_policy": "most_restrictive_action_wins",
    "missing_data_policy": "report_unassessed_coverage_gap",
    "actions_ranked_most_to_least_restrictive": [
      "permanently_discontinue",
      "contraindicated",
      "discontinue",
      "cease",
      "omit",
      "withhold_then_reduce",
      "withhold",
      "delay_then_dose_reduce",
      "delay",
      "consultant_review",
      "dose_reduce_two_levels",
      "dose_reduce_one_level",
      "dose_reduce",
      "proceed_with_caution",
      "proceed"
    ],
    "rules": [
      {
        "rule_id": "EXCLUSION_HYPERSENSITIVITY",
        "field": "hypersensitivity",
        "operator": "==",
        "value": true,
        "action": {
          "type": "contraindicated",
          "components": [
            "atezolizumab"
          ],
          "recommendation": "Do not administer atezolizumab; obtain consultant review."
        },
        "source": {
          "page": 2
        },
        "explanation": "Relevant hypersensitivity is an exclusion."
      },
      {
        "rule_id": "PREGNANCY_OR_BREASTFEEDING_REVIEW",
        "any": [
          {
            "field": "pregnancy",
            "operator": "==",
            "value": true
          },
          {
            "field": "breastfeeding",
            "operator": "==",
            "value": true
          }
        ],
        "action": {
          "type": "consultant_review",
          "components": [
            "atezolizumab"
          ],
          "recommendation": "Do not proceed without urgent consultant review of pregnancy or breastfeeding risk."
        },
        "source": {
          "page": 3
        },
        "explanation": "Pregnancy or breastfeeding requires specialist review."
      },
      {
        "rule_id": "ACTIVE_INFECTION_REQUIRING_THERAPY",
        "field": "active_infection_requiring_therapy",
        "operator": "==",
        "value": true,
        "action": {
          "type": "withhold",
          "components": [
            "atezolizumab"
          ],
          "recommendation": "Withhold atezolizumab and treat/review the infection until clinically stable."
        },
        "source": {
          "page": 3
        },
        "explanation": "Clinically significant active infection requires review before treatment."
      },
      {
        "rule_id": "FBC_ABNORMALITY_REVIEW",
        "field": "fbc_clinical_concern",
        "operator": "==",
        "value": true,
        "action": {
          "type": "consultant_review",
          "components": [
            "atezolizumab"
          ],
          "recommendation": "Review the FBC abnormality clinically; no protocol-defined ANC or platelet hold threshold is encoded for single-agent atezolizumab."
        },
        "source": {
          "page": 4
        },
        "explanation": "FBC is monitored, but NCCP 00593 does not specify an ANC or platelet treatment threshold."
      },
      {
        "rule_id": "PNEUMONITIS_G2",
        "field": "pneumonitis_grade",
        "operator": "==",
        "value": 2,
        "action": {
          "type": "withhold",
          "components": [
            "atezolizumab"
          ],
          "recommendation": "Withhold atezolizumab and manage as immune-mediated pneumonitis."
        },
        "source": {
          "page": 4
        },
        "explanation": "Grade 2 pneumonitis requires withholding."
      },
      {
        "rule_id": "PNEUMONITIS_G3_G4",
        "field": "pneumonitis_grade",
        "operator": ">=",
        "value": 3,
        "action": {
          "type": "permanently_discontinue",
          "components": [
            "atezolizumab"
          ],
          "recommendation": "Permanently discontinue atezolizumab for grade 3–4 pneumonitis."
        },
        "source": {
          "page": 4
        },
        "explanation": "Grade 3–4 pneumonitis requires permanent discontinuation."
      },
      {
        "rule_id": "HEPATITIS_WITHHOLD",
        "any": [
          {
            "all": [
              {
                "field": "alt_ast_uln_multiple",
                "operator": ">",
                "value": 3
              },
              {
                "field": "alt_ast_uln_multiple",
                "operator": "<=",
                "value": 5
              }
            ]
          },
          {
            "all": [
              {
                "field": "bilirubin_uln_multiple",
                "operator": ">",
                "value": 1.5
              },
              {
                "field": "bilirubin_uln_multiple",
                "operator": "<=",
                "value": 3
              }
            ]
          }
        ],
        "action": {
          "type": "withhold",
          "components": [
            "atezolizumab"
          ],
          "recommendation": "Withhold atezolizumab and manage as immune-mediated hepatitis."
        },
        "source": {
          "page": 4
        },
        "explanation": "ALT/AST >3–5×ULN or bilirubin >1.5–3×ULN requires withholding."
      },
      {
        "rule_id": "HEPATITIS_PERMANENT",
        "any": [
          {
            "field": "alt_ast_uln_multiple",
            "operator": ">",
            "value": 5
          },
          {
            "field": "bilirubin_uln_multiple",

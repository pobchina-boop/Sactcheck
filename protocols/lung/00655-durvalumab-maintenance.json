  "rule_engine": {
    "conflict_policy": "most_restrictive_action_wins",
    "missing_data_policy": "report_unassessed_coverage_gap",
    "actions_ranked_most_to_least_restrictive": [
      "permanently_discontinue",
      "contraindicated",
      "discontinue",
      "cease",
      "omit",
      "withhold_then_reduce",
      "withhold",
      "delay_then_dose_reduce",
      "delay",
      "consultant_review",
      "dose_reduce_two_levels",
      "dose_reduce_one_level",
      "dose_reduce",
      "proceed_with_caution",
      "proceed"
    ],
    "rules": [
      {
        "rule_id": "EXCLUSION_HYPERSENSITIVITY",
        "field": "hypersensitivity",
        "operator": "==",
        "value": true,
        "action": {
          "type": "contraindicated",
          "components": [
            "durvalumab"
          ],
          "recommendation": "Do not administer this regimen; obtain consultant review."
        },
        "source": {
          "page": 2
        },
        "explanation": "Relevant hypersensitivity is an exclusion."
      },
      {
        "rule_id": "EXCLUSION_PREGNANCY_LACTATION",
        "any": [
          {
            "field": "pregnancy",
            "operator": "==",
            "value": true
          },
          {
            "field": "breastfeeding",
            "operator": "==",
            "value": true
          }
        ],
        "action": {
          "type": "contraindicated",
          "components": [
            "durvalumab"
          ],
          "recommendation": "Do not administer; urgent consultant review required."
        },
        "source": {
          "page": 2
        },
        "explanation": "Pregnancy or breastfeeding is an exclusion/caution for this regimen."
      },
      {
        "rule_id": "ACTIVE_INFECTION",
        "field": "active_infection",
        "operator": "==",
        "value": true,
        "action": {
          "type": "withhold",
          "components": [
            "durvalumab"
          ],
          "recommendation": "Withhold and assess/treat infection; discuss with consultant."
        },
        "source": {
          "page": 3
        },
        "explanation": "Clinically significant infection requires review before treatment."
      },
      {
        "rule_id": "ANC_LOW",
        "field": "anc",
        "operator": "<",
        "value": 1.0,
        "action": {
          "type": "delay",
          "components": [
            "durvalumab"
          ],
          "recommendation": "Delay treatment and repeat FBC; discuss dose modification with consultant."
        },
        "source": {
          "page": 4
        },
        "explanation": "ANC below treatment threshold."
      },
      {
        "rule_id": "PLATELETS_LOW",
        "field": "platelets",
        "operator": "<",
        "value": 75,
        "action": {
          "type": "delay",
          "components": [
            "durvalumab"
          ],
          "recommendation": "Delay treatment and repeat FBC; discuss dose modification with consultant."
        },
        "source": {
          "page": 4
        },
        "explanation": "Platelets below treatment threshold."
      },
      {
        "rule_id": "DIARRHOEA_G3PLUS",
        "field": "diarrhoea_grade",
        "operator": ">=",
        "value": 3,
        "action": {
          "type": "withhold_then_reduce",
          "components": [
            "durvalumab"
          ],
          "recommendation": "Withhold until recovery and consider dose reduction according to the NCCP table."
        },
        "source": {
          "page": 5
        },
        "explanation": "Severe diarrhoea requires withholding and dose review."
      },
      {
        "rule_id": "STOMATITIS_G3PLUS",
        "field": "stomatitis_grade",
        "operator": ">=",
        "value": 3,
        "action": {
          "type": "withhold_then_reduce",
          "components": [
            "durvalumab"
          ],
          "recommendation": "Withhold until recovery and consider dose reduction according to the NCCP table."
        },
        "source": {
          "page": 5
        },
        "explanation": "Severe mucositis requires withholding and dose review."
      },
      {
        "rule_id": "IO_PNEUMONITIS_G2",
        "field": "pneumonitis_grade",
        "operator": ">=",
        "value": 2,
        "action": {
          "type": "withhold",
          "components": [
            "durvalumab"
          ],
          "recommendation": "Withhold immunotherapy and manage suspected immune-mediated pneumonitis per NCCP guidance."
        },
        "source": {
          "page": 5
        },
        "explanation": "Grade \u22652 pneumonitis requires withholding."
      },
      {
        "rule_id": "IO_PNEUMONITIS_G3",
        "field": "pneumonitis_grade",
        "operator": ">=",
        "value": 3,
        "action": {
          "type": "permanently_discontinue",
          "components": [
            "durvalumab"
          ],
          "recommendation": "Permanently discontinue and urgently manage severe pneumonitis."
        },
        "source": {
          "page": 5
        },
        "explanation": "Severe pneumonitis requires permanent discontinuation."
      },
      {
        "rule_id": "IO_OTHER_G3",
        "field": "immune_toxicity_grade",
        "operator": ">=",
        "value": 3,
        "action": {
          "type": "withhold",
          "components": [
            "durvalumab"
          ],
          "recommendation": "Withhold and manage immune-related adverse event; assess criteria for permanent discontinuation."
        },
        "source": {
          "page": 6
        },
        "explanation": "Severe immune toxicity requires interruption."
      },
      {
        "rule_id": "CRT_WINDOW",
        "field": "days_since_chemoradiotherapy",
        "operator": ">",
        "value": 42,
        "action": {
          "type": "consultant_review",
          "components": [
            "durvalumab"
          ],
          "recommendation": "Cycle 1 is outside the NCCP 42-day commencement window; consultant eligibility review required."
        },
        "source": {
          "page": 1
        },
        "explanation": "Durvalumab should commence within 42 days of CRT."
      },
      {
        "rule_id": "PROGRESSION",
        "field": "disease_progressed_after_crt",
        "operator": "==",
        "value": true,
        "action": {
          "type": "contraindicated",
          "components": [
            "durvalumab"
          ],
          "recommendation": "Do not administer as consolidation where disease has progressed after CRT."
        },
        "source": {
          "page": 1
        },
        "explanation": "No progression after CRT is required."
      }
    ]
  },

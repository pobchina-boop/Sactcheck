        "operator": ">=",
        "value": 2,
        "action": {
          "type": "discontinue",
          "components": [
            "gemcitabine"
          ],
          "recommendation": "Discontinue gemcitabine for grade ≥2 pneumonitis."
        },
        "source": {
          "page": 3
        },
        "explanation": "Clinically significant pneumonitis requires discontinuation."
      },
      {

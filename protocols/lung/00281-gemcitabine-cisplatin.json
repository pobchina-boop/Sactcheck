        },
        "source": {
          "page": 2
        },
        "explanation": "Baseline grade ≥2 neuropathy is a cisplatin exclusion."
      },
      {
        "rule_id": "HEARING_IMPAIRMENT_REVIEW",
        "field": "significant_hearing_impairment_or_tinnitus",
        "operator": "==",
        "value": true,
        "action": {
          "type": "consultant_review",
          "components": [
            "cisplatin"
          ],
          "recommendation": "Review cisplatin suitability because significant hearing impairment/tinnitus is an exclusion."
        },
        "source": {
          "page": 2
        },
        "explanation": "Cisplatin ototoxicity risk requires review."
      },
      {
        "rule_id": "DAY1_COUNTS_LOW",
        "all": [
          {
            "field": "treatment_day",
            "operator": "==",
            "value": "day1"
          },
          {
            "any": [
              {
                "field": "anc",
                "operator": "<=",
                "value": 1.0
              },
              {
                "field": "platelets",
                "operator": "<=",
                "value": 100
              }
            ]
          }
        ],
        "action": {
          "type": "delay",
          "components": [
            "gemcitabine",
            "cisplatin"
          ],
          "recommendation": "Delay the new cycle and repeat FBC; Day 1 requires ANC >1.0 and platelets >100 ×10⁹/L."
        },
        "source": {
          "page": 3
        },
        "explanation": "Day-1 count threshold."
      },
      {
        "rule_id": "DAY8_OMIT",
        "all": [
          {
            "field": "treatment_day",
            "operator": "==",
            "value": "day8"
          },
          {
            "any": [
              {
                "field": "anc",
                "operator": "<",
                "value": 0.5
              },
              {
                "field": "platelets",
                "operator": "<",
                "value": 50
              }
            ]
          }
        ],
        "action": {
          "type": "omit",
          "components": [
            "gemcitabine"
          ],
          "recommendation": "Omit day-8 gemcitabine; do not restart until ANC >0.5 and platelets >50 ×10⁹/L."
        },
        "source": {
          "page": 3
        },
        "explanation": "Day-8 severe cytopenia requires omission."
      },
      {
        "rule_id": "DAY8_75_PERCENT",
        "all": [
          {
            "field": "treatment_day",
            "operator": "==",
            "value": "day8"
          },
          {
            "any": [
              {
                "all": [
                  {
                    "field": "anc",
                    "operator": ">=",
                    "value": 0.5
                  },
                  {
                    "field": "anc",
                    "operator": "<=",
                    "value": 1.0
                  }
                ]
              },
              {
                "all": [
                  {
                    "field": "platelets",
                    "operator": ">=",
                    "value": 50
                  },
                  {
                    "field": "platelets",
                    "operator": "<=",
                    "value": 100
                  }
                ]
              }
            ]
          }
        ],
        "action": {
          "type": "dose_reduce",
          "components": [
            "gemcitabine"
          ],
          "recommendation": "Administer day-8 gemcitabine at 75%."
        },
        "source": {
          "page": 3
        },
        "explanation": "Day-8 intermediate cytopenia requires 75% dosing."
      },
      {
        "rule_id": "PRIOR_HAEM_EVENT_REDUCE",
        "field": "haematologic_event",
        "operator": "!=",
        "value": "none",
        "action": {
          "type": "dose_reduce",
          "components": [
            "gemcitabine",
            "cisplatin"
          ],
          "recommendation": "Reduce subsequent cycles to 75% of the original cycle-initiation dose after the selected severe haematologic event."
        },
        "source": {
          "page": 3
        },
        "explanation": "Severe prior-cycle haematologic toxicity requires subsequent reduction."
      },
      {
        "rule_id": "CISPLATIN_CRCL_45_TO_59",
        "all": [
          {
            "field": "crcl_ml_min",
            "operator": ">=",
            "value": 45
          },
          {
            "field": "crcl_ml_min",
            "operator": "<=",
            "value": 59
          }
        ],
        "action": {
          "type": "dose_reduce",
          "components": [
            "cisplatin"
          ],
          "recommendation": "Use cisplatin at 75% for creatinine clearance 45–59 mL/min after consultant/pharmacy verification."
        },
        "source": {
          "page": 3
        },
        "explanation": "NCCP renal dose modification."
      },
      {
        "rule_id": "CISPLATIN_CRCL_LT45",
        "field": "crcl_ml_min",
        "operator": "<",
        "value": 45,
        "action": {
          "type": "consultant_review",
          "components": [
            "cisplatin"
          ],
          "recommendation": "Consider carboplatin instead of cisplatin; this is a clinical decision."
        },
        "source": {
          "page": 3
        },
        "explanation": "Creatinine clearance <45 mL/min requires alternative platinum review."
      },
      {
        "rule_id": "GEMCITABINE_CRCL_LT30",
        "field": "crcl_ml_min",
        "operator": "<",
        "value": 30,
        "action": {
          "type": "consultant_review",
          "components": [
            "gemcitabine"
          ],
          "recommendation": "Consider gemcitabine dose reduction in creatinine clearance <30 mL/min."
        },
        "source": {
          "page": 3
        },
        "explanation": "Severe renal impairment requires clinical dose review."
      },
      {
        "rule_id": "GEMCITABINE_BILIRUBIN_27_PLUS",
        "field": "bilirubin_micromol_l",
        "operator": ">=",
        "value": 27,
        "action": {
          "type": "dose_reduce",
          "components": [
            "gemcitabine"
          ],
          "recommendation": "Use gemcitabine 800 mg/m² and increase toward full dose if tolerated."
        },
        "source": {
          "page": 3
        },
        "explanation": "NCCP hepatic dose modification."
      },
      {
        "rule_id": "NONHAEM_G3PLUS",
        "field": "nonhaem_toxicity_grade",
        "operator": ">=",
        "value": 3,
        "action": {
          "type": "withhold_then_reduce",
          "components": [
            "gemcitabine",
            "cisplatin"
          ],
          "recommendation": "Withhold until toxicity resolves to grade ≤1, then consider dose reduction."
        },
        "source": {
          "page": 3
        },
        "explanation": "Grade ≥3 non-haematologic toxicity requires withholding."
      },
      {
        "rule_id": "NEUROPATHY_G2PLUS",
        "field": "neuropathy_grade",
        "operator": ">=",
        "value": 2,
        "action": {
          "type": "withhold_then_reduce",
          "components": [
            "cisplatin"
          ],
          "recommendation": "After recovery to grade ≤1, substitute carboplatin AUC5 or reduce cisplatin by 50%; continue gemcitabine at 100%."
        },
        "source": {
          "page": 3
        },
        "explanation": "Grade ≥2 neuropathy requires platinum modification."
      },
      {
        "rule_id": "PNEUMONITIS_G2PLUS",

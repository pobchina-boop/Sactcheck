  "rule_engine": {
    "conflict_policy": "most_restrictive_action_wins",
    "missing_data_policy": "Missing optional inputs are never interpreted as normal; report unassessed domains.",
    "actions_ranked_most_to_least_restrictive": [
      "permanently_discontinue",
      "contraindicated",
      "discontinue",
      "cease",
      "omit",
      "withhold_then_reduce",
      "withhold",
      "delay_then_dose_reduce",
      "delay",
      "consultant_review",
      "dose_reduce_two_levels",
      "dose_reduce_one_level",
      "dose_reduce",
      "proceed_with_caution",
      "proceed"
    ],
    "rules": [
      {
        "rule_id": "EXCLUSION_HYPERSENSITIVITY",
        "field": "hypersensitivity",
        "operator": "==",
        "value": true,
        "action": {
          "type": "contraindicated",
          "components": [
            "gemcitabine",
            "carboplatin"
          ],
          "recommendation": "Do not administer this regimen; obtain consultant review."
        },
        "source": {
          "page": 3
        },
        "explanation": "Relevant hypersensitivity is an exclusion."
      },
      {
        "rule_id": "PREGNANCY_LACTATION",
        "field": "pregnancy_or_breastfeeding",
        "operator": "==",
        "value": true,
        "action": {
          "type": "contraindicated",
          "components": [
            "gemcitabine",
            "carboplatin"
          ],
          "recommendation": "Do not administer without urgent consultant review."
        },
        "source": {
          "page": 3
        },
        "explanation": "Pregnancy or breastfeeding requires urgent specialist review."
      },
      {
        "rule_id": "ACTIVE_INFECTION",
        "field": "active_infection",
        "operator": "==",
        "value": true,
        "action": {
          "type": "withhold",
          "components": [
            "gemcitabine",
            "carboplatin"
          ],
          "recommendation": "Withhold treatment and assess/treat the infection."
        },
        "source": {
          "page": 3
        },
        "explanation": "Clinically significant infection requires review."
      },
      {
        "rule_id": "DAY1_COUNTS_LOW",
        "all": [
          {
            "field": "treatment_day",
            "operator": "==",
            "value": "day1"
          },
          {
            "any": [
              {
                "field": "anc",
                "operator": "<=",
                "value": 1.0
              },
              {
                "field": "platelets",
                "operator": "<=",
                "value": 100
              }
            ]
          }
        ],
        "action": {
          "type": "delay",
          "components": [
            "gemcitabine",
            "carboplatin"
          ],
          "recommendation": "Delay the new cycle and repeat FBC; Day 1 requires ANC >1.0 and platelets >100 ×10⁹/L."
        },
        "source": {
          "page": 4
        },
        "explanation": "Day-1 count threshold."
      },
      {
        "rule_id": "DAY8_OMIT",
        "all": [
          {
            "field": "treatment_day",
            "operator": "==",
            "value": "day8"
          },
          {
            "any": [
              {
                "field": "anc",
                "operator": "<",
                "value": 0.5
              },
              {
                "field": "platelets",
                "operator": "<",
                "value": 50
              }
            ]
          }
        ],
        "action": {
          "type": "omit",
          "components": [
            "gemcitabine"
          ],
          "recommendation": "Omit day-8 gemcitabine; do not restart until ANC >0.5 and platelets >50 ×10⁹/L."
        },
        "source": {
          "page": 4
        },
        "explanation": "Day-8 severe cytopenia requires omission."
      },
      {
        "rule_id": "DAY8_75_PERCENT",
        "all": [
          {
            "field": "treatment_day",
            "operator": "==",
            "value": "day8"
          },
          {
            "any": [
              {
                "all": [
                  {
                    "field": "anc",
                    "operator": ">=",
                    "value": 0.5
                  },
                  {
                    "field": "anc",
                    "operator": "<=",
                    "value": 1.0
                  }
                ]
              },
              {
                "all": [
                  {
                    "field": "platelets",
                    "operator": ">=",
                    "value": 50
                  },
                  {
                    "field": "platelets",
                    "operator": "<=",
                    "value": 100
                  }
                ]
              }
            ]
          }
        ],
        "action": {
          "type": "dose_reduce",
          "components": [
            "gemcitabine"
          ],
          "recommendation": "Administer day-8 gemcitabine at 75%."
        },
        "source": {
          "page": 4
        },
        "explanation": "Day-8 intermediate cytopenia requires 75% dosing."
      },
      {
        "rule_id": "PRIOR_HAEM_EVENT_REDUCE",
        "field": "haematologic_event",
        "operator": "!=",
        "value": "none",
        "action": {
          "type": "dose_reduce",
          "components": [
            "gemcitabine",
            "carboplatin"
          ],
          "recommendation": "Reduce subsequent cycles to 75% of the original cycle-initiation dose after the selected severe haematologic event."
        },
        "source": {
          "page": 4
        },
        "explanation": "Severe prior-cycle haematologic toxicity requires subsequent reduction."
      },
      {
        "rule_id": "CARBOPLATIN_GFR_20_OR_LESS",
        "field": "gfr_ml_min",
        "operator": "<=",
        "value": 20,
        "action": {
          "type": "contraindicated",
          "components": [
            "carboplatin"
          ],
          "recommendation": "Do not administer carboplatin at GFR ≤20 mL/min."
        },
        "source": {
          "page": 4
        },
        "explanation": "Carboplatin should not be administered at GFR ≤20."
      },
      {
        "rule_id": "CARBOPLATIN_GFR_20_TO_30",
        "all": [
          {
            "field": "gfr_ml_min",
            "operator": ">",
            "value": 20
          },
          {
            "field": "gfr_ml_min",
            "operator": "<=",
            "value": 30
          }
        ],
        "action": {
          "type": "consultant_review",
          "components": [
            "carboplatin"
          ],
          "recommendation": "Use carboplatin with extreme caution at GFR 20–30 mL/min; consultant/pharmacy review required."
        },
        "source": {
          "page": 4
        },
        "explanation": "Severe renal impairment requires extreme caution."
      },
      {
        "rule_id": "GEMCITABINE_BILIRUBIN_27_PLUS",
        "field": "bilirubin_micromol_l",
        "operator": ">=",
        "value": 27,
        "action": {
          "type": "consultant_review",
          "components": [
            "gemcitabine"
          ],
          "recommendation": "For bilirubin ≥27 µmol/L, consider starting gemcitabine at 80% with escalation if tolerated, or full dose with active monitoring."
        },
        "source": {
          "page": 4
        },
        "explanation": "Hepatic impairment requires an individualised NCCP option."
      },
      {
        "rule_id": "NONHAEM_G3PLUS",
        "field": "nonhaem_toxicity_grade",
        "operator": ">=",
        "value": 3,
        "action": {
          "type": "withhold_then_reduce",
          "components": [
            "gemcitabine",
            "carboplatin"
          ],
          "recommendation": "Withhold until toxicity resolves to grade ≤1, then consider dose reduction."
        },
        "source": {
          "page": 5
        },
        "explanation": "Grade ≥3 non-haematologic toxicity requires withholding and review."
      },
      {
        "rule_id": "PNEUMONITIS_G2PLUS",
        "field": "pneumonitis_grade",
        "operator": ">=",
        "value": 2,
        "action": {
          "type": "discontinue",
          "components": [
            "gemcitabine"
          ],
          "recommendation": "Discontinue gemcitabine for grade ≥2 pneumonitis and assess urgently."
        },
        "source": {
          "page": 5
        },
        "explanation": "Clinically significant pneumonitis requires gemcitabine discontinuation."
      },
      {
        "rule_id": "SCAR_CONFIRMED",
        "field": "scar_status",
        "operator": "==",
        "value": "confirmed",
        "action": {
          "type": "permanently_discontinue",
          "components": [
            "gemcitabine"
          ],
          "recommendation": "Permanently discontinue gemcitabine for confirmed severe cutaneous adverse reaction."
        },
        "source": {
          "page": 5
        },
        "explanation": "Confirmed SCAR requires permanent discontinuation."
      },
      {
        "rule_id": "SCAR_SUSPECTED",
        "field": "scar_status",
        "operator": "==",
        "value": "suspected",
        "action": {
          "type": "withhold",
          "components": [
            "gemcitabine"
          ],
          "recommendation": "Withhold gemcitabine while suspected SCAR is urgently evaluated."
        },
        "source": {
          "page": 5
        },
        "explanation": "Suspected SCAR requires withholding."
      },
      {
        "rule_id": "HAEMODIALYSIS_TIMING",
        "field": "haemodialysis",
        "operator": "==",
        "value": true,
        "action": {
          "type": "consultant_review",
          "components": [
            "gemcitabine"
          ],
          "recommendation": "Confirm gemcitabine and dialysis timing with oncology pharmacy; the NCCP notes haemodialysis 6–12 hours after administration."
        },
        "source": {
          "page": 4
        },
        "explanation": "Dialysis timing requires pharmacy confirmation."
      },
      {
        "rule_id": "PROCEED_IF_NO_RESTRICTIVE_RULE",
        "field": "cycle_number",
        "operator": ">=",
        "value": 1,
        "action": {
          "type": "proceed",
          "components": [],
          "recommendation": "No restrictive encoded rule was triggered by the entered assessment data."
        },
        "source": {
          "page": 1
        },
        "explanation": "Fallback proceed finding; any restrictive matched rule takes precedence."
      }
    ]
  },
  "output_templates": {
    "proceed": "No encoded hold, discontinuation, or modification criterion was triggered by the entered data.",

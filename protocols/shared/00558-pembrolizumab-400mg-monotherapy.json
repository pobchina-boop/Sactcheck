  "rule_engine": {
    "conflict_policy": "most_restrictive_action_wins",
    "missing_data_policy": "report_unassessed_coverage_gap",
    "actions_ranked_most_to_least_restrictive": [
      "permanently_discontinue",
      "contraindicated",
      "discontinue",
      "cease",
      "omit",
      "withhold_then_reduce",
      "withhold",
      "delay_then_dose_reduce",
      "delay",
      "consultant_review",
      "dose_reduce_two_levels",
      "dose_reduce_one_level",
      "dose_reduce",
      "proceed_with_caution",
      "proceed"
    ],
    "rules": [
      {
        "rule_id": "EXCLUSION_HYPERSENSITIVITY",
        "field": "hypersensitivity",
        "operator": "==",
        "value": true,
        "action": {
          "type": "contraindicated",
          "components": [
            "pembrolizumab"
          ],
          "recommendation": "Do not administer pembrolizumab; obtain consultant review."
        },
        "source": {
          "page": 4
        },
        "explanation": "Relevant hypersensitivity is an exclusion."
      },
      {
        "rule_id": "PREGNANCY_BREASTFEEDING_REVIEW",
        "any": [
          {
            "field": "pregnancy",
            "operator": "==",
            "value": true
          },
          {
            "field": "breastfeeding",
            "operator": "==",
            "value": true
          }
        ],
        "action": {
          "type": "contraindicated",
          "components": [
            "pembrolizumab"
          ],
          "recommendation": "Do not administer during pregnancy or breastfeeding without urgent consultant review."
        },
        "source": {
          "page": 4
        },
        "explanation": "Pregnancy/breastfeeding requires specialist review."
      },
      {
        "rule_id": "AUTOIMMUNE_DISEASE_REVIEW",
        "field": "prior_serious_autoimmune_disease",
        "operator": "==",
        "value": true,
        "action": {
          "type": "consultant_review",
          "components": [
            "pembrolizumab"
          ],
          "recommendation": "History of serious autoimmune disease requires consultant review before treatment."
        },
        "source": {
          "page": 4
        },
        "explanation": "Serious autoimmune disease is a caution."
      },
      {
        "rule_id": "ACTIVE_INFECTION",
        "field": "active_infection_requiring_therapy",
        "operator": "==",
        "value": true,
        "action": {
          "type": "withhold",
          "components": [
            "pembrolizumab"
          ],
          "recommendation": "Withhold pembrolizumab until the clinically significant infection is assessed and stable."
        },
        "source": {
          "page": 4
        },
        "explanation": "Active clinically significant infection requiring therapy is a caution."
      },
      {
        "rule_id": "SYSTEMIC_STEROIDS",
        "field": "systemic_steroids_mg_pred",
        "operator": ">",
        "value": 10,
        "action": {
          "type": "consultant_review",
          "components": [
            "pembrolizumab"
          ],
          "recommendation": "Systemic corticosteroid dose exceeds 10 mg prednisolone equivalent/day; confirm indication and consultant approval."
        },
        "source": {
          "page": 4
        },
        "explanation": "Immunosuppressive systemic steroid doses are a caution."
      },
      {
        "rule_id": "FBC_CLINICAL_REVIEW",
        "field": "fbc_clinical_concern",
        "operator": "==",
        "value": true,
        "action": {
          "type": "consultant_review",
          "components": [
            "pembrolizumab"
          ],
          "recommendation": "Review the FBC abnormality clinically; no numerical chemotherapy-style count threshold is encoded for monotherapy."
        },
        "source": {
          "page": 4
        },
        "explanation": "FBC is monitored but numerical cytotoxic hold criteria are not specified."
      },
      {
        "rule_id": "PNEUMONITIS_G2",
        "field": "pneumonitis_grade",
        "operator": "==",
        "value": 2,
        "action": {
          "type": "withhold",
          "components": [
            "pembrolizumab"
          ],
          "recommendation": "Withhold pembrolizumab for grade 2 pneumonitis."
        },
        "source": {
          "page": 5,
          "table": "Table 1"
        },
        "explanation": "Grade 2 pneumonitis requires withholding."
      },
      {
        "rule_id": "PNEUMONITIS_SEVERE_OR_RECURRENT",
        "any": [
          {
            "field": "pneumonitis_grade",
            "operator": ">=",
            "value": 3
          },
          {
            "field": "recurrent_grade2_pneumonitis",
            "operator": "==",
            "value": true
          }
        ],
        "action": {
          "type": "permanently_discontinue",
          "components": [
            "pembrolizumab"
          ],
          "recommendation": "Permanently discontinue pembrolizumab for grade 3–4 or recurrent grade 2 pneumonitis."
        },
        "source": {
          "page": 5,
          "table": "Table 1"
        },
        "explanation": "Severe or recurrent pneumonitis requires permanent discontinuation."
      },
      {
        "rule_id": "COLITIS_G2_G3",
        "all": [
          {
            "field": "diarrhoea_colitis_grade",
            "operator": ">=",
            "value": 2
          },
          {
            "field": "diarrhoea_colitis_grade",
            "operator": "<=",
            "value": 3
          }
        ],
        "action": {
          "type": "withhold",
          "components": [
            "pembrolizumab"
          ],
          "recommendation": "Withhold pembrolizumab for grade 2–3 immune-mediated diarrhoea/colitis."
        },
        "source": {
          "page": 5,
          "table": "Table 1"
        },
        "explanation": "Grade 2–3 colitis requires withholding."
      },
      {
        "rule_id": "COLITIS_G4_OR_RECURRENT_G3",
        "any": [
          {
            "field": "diarrhoea_colitis_grade",
            "operator": ">=",
            "value": 4
          },
          {
            "field": "recurrent_grade3_colitis",
            "operator": "==",
            "value": true
          }
        ],
        "action": {
          "type": "permanently_discontinue",
          "components": [
            "pembrolizumab"
          ],
          "recommendation": "Permanently discontinue pembrolizumab for grade 4 or recurrent grade 3 colitis."
        },
        "source": {
          "page": 5,

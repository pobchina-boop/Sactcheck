  "rule_engine": {
    "conflict_policy": "most_restrictive_action_wins",
    "missing_data_policy": "report_unassessed_coverage_gap",
    "actions_ranked_most_to_least_restrictive": [
      "permanently_discontinue",
      "contraindicated",
      "discontinue",
      "cease",
      "omit",
      "withhold_then_reduce",
      "withhold",
      "delay_then_dose_reduce",
      "delay",
      "consultant_review",
      "dose_reduce_two_levels",
      "dose_reduce_one_level",
      "dose_reduce",
      "proceed_with_caution",
      "proceed"
    ],
    "rules": [
      {
        "rule_id": "EXCLUSION_HYPERSENSITIVITY",
        "field": "hypersensitivity",
        "operator": "==",
        "value": true,
        "action": {
          "type": "contraindicated",
          "components": [
            "bevacizumab",
            "carboplatin",
            "paclitaxel"
          ],
          "recommendation": "Do not administer this regimen; obtain consultant review."
        },
        "source": {
          "page": 2
        },
        "explanation": "Relevant hypersensitivity is an exclusion."
      },
      {
        "rule_id": "EXCLUSION_PREGNANCY_LACTATION",
        "any": [
          {
            "field": "pregnancy",
            "operator": "==",
            "value": true
          },
          {
            "field": "breastfeeding",
            "operator": "==",
            "value": true
          }
        ],
        "action": {
          "type": "contraindicated",
          "components": [
            "bevacizumab",
            "carboplatin",
            "paclitaxel"
          ],
          "recommendation": "Do not administer; urgent consultant review required."
        },
        "source": {
          "page": 2
        },
        "explanation": "Pregnancy or breastfeeding is an exclusion/caution for this regimen."
      },
      {
        "rule_id": "ACTIVE_INFECTION",
        "field": "active_infection",
        "operator": "==",
        "value": true,
        "action": {
          "type": "withhold",
          "components": [
            "bevacizumab",
            "carboplatin",
            "paclitaxel"
          ],
          "recommendation": "Withhold and assess/treat infection; discuss with consultant."
        },
        "source": {
          "page": 3
        },
        "explanation": "Clinically significant infection requires review before treatment."
      },
      {
        "rule_id": "ANC_LOW",
        "field": "anc",
        "operator": "<",
        "value": 1.0,
        "action": {
          "type": "delay",
          "components": [
            "bevacizumab",
            "carboplatin",
            "paclitaxel"
          ],
          "recommendation": "Delay treatment and repeat FBC; discuss dose modification with consultant."
        },
        "source": {
          "page": 4
        },
        "explanation": "ANC below treatment threshold."
      },
      {
        "rule_id": "PLATELETS_LOW",
        "field": "platelets",
        "operator": "<",
        "value": 75,
        "action": {
          "type": "delay",
          "components": [
            "bevacizumab",
            "carboplatin",
            "paclitaxel"
          ],
          "recommendation": "Delay treatment and repeat FBC; discuss dose modification with consultant."
        },
        "source": {
          "page": 4
        },
        "explanation": "Platelets below treatment threshold."
      },
      {
        "rule_id": "DIARRHOEA_G3PLUS",
        "field": "diarrhoea_grade",
        "operator": ">=",
        "value": 3,
        "action": {
          "type": "withhold_then_reduce",
          "components": [
            "bevacizumab",
            "carboplatin",
            "paclitaxel"
          ],
          "recommendation": "Withhold until recovery and consider dose reduction according to the NCCP table."
        },
        "source": {
          "page": 5
        },
        "explanation": "Severe diarrhoea requires withholding and dose review."
      },
      {
        "rule_id": "STOMATITIS_G3PLUS",
        "field": "stomatitis_grade",
        "operator": ">=",
        "value": 3,
        "action": {
          "type": "withhold_then_reduce",
          "components": [
            "bevacizumab",
            "carboplatin",
            "paclitaxel"
          ],
          "recommendation": "Withhold until recovery and consider dose reduction according to the NCCP table."
        },
        "source": {
          "page": 5
        },
        "explanation": "Severe mucositis requires withholding and dose review."
      },
      {
        "rule_id": "BEV_BP",
        "any": [
          {
            "field": "systolic_bp",
            "operator": ">=",
            "value": 160
          },
          {
            "field": "diastolic_bp",
            "operator": ">=",
            "value": 100
          }
        ],
        "action": {
          "type": "withhold",
          "components": [
            "bevacizumab"
          ],
          "recommendation": "Withhold bevacizumab until hypertension is controlled; manage and review per NCCP."
        },
        "source": {
          "page": 6
        },
        "explanation": "Uncontrolled hypertension requires withholding."
      },
      {
        "rule_id": "BEV_PROTEIN_G3",
        "field": "proteinuria_grade",
        "operator": ">=",
        "value": 3,
        "action": {
          "type": "withhold",
          "components": [
            "bevacizumab"
          ],
          "recommendation": "Withhold bevacizumab and quantify proteinuria; permanently discontinue for nephrotic syndrome."
        },
        "source": {
          "page": 6
        },
        "explanation": "Significant proteinuria requires interruption."
      },
      {
        "rule_id": "BEV_SURGERY",
        "field": "recent_major_surgery",
        "operator": "==",
        "value": true,
        "action": {
          "type": "withhold",
          "components": [
            "bevacizumab"
          ],
          "recommendation": "Withhold bevacizumab until adequate wound healing and the NCCP interval is satisfied."
        },
        "source": {
          "page": 7
        },
        "explanation": "Bevacizumab impairs wound healing."
      },
      {
        "rule_id": "BEV_BLEED",
        "field": "active_bleeding",
        "operator": "==",
        "value": true,
        "action": {
          "type": "permanently_discontinue",
          "components": [
            "bevacizumab"
          ],
          "recommendation": "Do not administer bevacizumab; urgent consultant review."
        },
        "source": {
          "page": 7
        },
        "explanation": "Clinically significant bleeding is a major contraindication."
      },
      {
        "rule_id": "BEV_PERF",
        "field": "gi_perforation_or_fistula",
        "operator": "==",
        "value": true,
        "action": {
          "type": "permanently_discontinue",
          "components": [
            "bevacizumab"
          ],
          "recommendation": "Permanently discontinue bevacizumab and manage urgently."
        },
        "source": {
          "page": 7
        },
        "explanation": "GI perforation/fistula requires permanent discontinuation."
      },
      {
        "rule_id": "PACLITAXEL_NEURO",
        "field": "neuropathy_grade",
        "operator": ">=",
        "value": 2,
        "action": {
          "type": "withhold_then_reduce",
          "components": [
            "paclitaxel"
          ],
          "recommendation": "Withhold paclitaxel until improvement and reduce according to NCCP."
        },
        "source": {
          "page": 5
        },
        "explanation": "Neuropathy requires paclitaxel modification."
      }
    ]
  },

  "rule_engine": {
    "conflict_policy": "most_restrictive_action_wins",
    "missing_data_policy": "report_unassessed_coverage_gap",
    "actions_ranked_most_to_least_restrictive": [
      "permanently_discontinue",
      "contraindicated",
      "discontinue",
      "cease",
      "omit",
      "withhold_then_reduce",
      "withhold",
      "delay_then_dose_reduce",
      "delay",
      "consultant_review",
      "dose_reduce_two_levels",
      "dose_reduce_one_level",
      "dose_reduce",
      "proceed_with_caution",
      "proceed"
    ],
    "rules": [
      {
        "rule_id": "EXCLUSION_HYPERSENSITIVITY",
        "field": "hypersensitivity",
        "operator": "==",
        "value": true,
        "action": {
          "type": "contraindicated",
          "components": [
            "niraparib"
          ],
          "recommendation": "Do not administer niraparib; obtain consultant review."
        },
        "source": {
          "page": 2
        },
        "explanation": "Hypersensitivity is an exclusion."
      },
      {
        "rule_id": "BREASTFEEDING",
        "field": "breastfeeding",
        "operator": "==",
        "value": true,
        "action": {
          "type": "contraindicated",
          "components": [
            "niraparib"
          ],
          "recommendation": "Do not administer niraparib while breastfeeding."
        },
        "source": {
          "page": 2
        },
        "explanation": "Breastfeeding is an exclusion."
      },
      {
        "rule_id": "CONTRACEPTION_NOT_MET",
        "field": "contraception_requirement_not_met",
        "operator": "==",
        "value": true,
        "action": {
          "type": "contraindicated",
          "components": [
            "niraparib"
          ],
          "recommendation": "Do not administer until the contraception requirement is addressed."
        },
        "source": {
          "page": 2
        },
        "explanation": "Women of child-bearing potential require effective contraception."
      },
      {
        "rule_id": "STARTING_DOSE_WEIGHT",
        "all": [
          {
            "field": "weight_kg",
            "operator": ">=",
            "value": 77
          },
          {
            "field": "indication_id",
            "operator": "==",
            "value": "first_line_advanced_maintenance"
          },
          {
            "field": "baseline_platelets",
            "operator": "<",
            "value": 150
          },
          {
            "field": "starting_dose_mg",
            "operator": "==",
            "value": "300"
          }
        ],
        "action": {
          "type": "consultant_review",
          "components": [
            "niraparib"
          ],
          "recommendation": "For body weight ≥77 kg, confirm whether the 300 mg starting dose applies; in first-line maintenance with baseline platelets <150 ×10⁹/L, the recommended start is 200 mg."
        },
        "source": {
          "page": 2
        },
        "explanation": "Starting dose depends on weight and, in first-line maintenance, baseline platelets."
      },
      {
        "rule_id": "ANC_OR_HB_LOW",
        "any": [
          {
            "field": "anc",
            "operator": "<",
            "value": 1.0
          },
          {
            "field": "haemoglobin_g_l",
            "operator": "<",
            "value": 80
          }
        ],
        "action": {
          "type": "withhold_then_reduce",
          "components": [
            "niraparib"
          ],
          "recommendation": "Withhold niraparib for up to 28 days with weekly counts; resume one dose level lower once ANC ≥1.5 and Hb ≥90 g/L."
        },
        "source": {
          "page": 4
        },
        "explanation": "ANC <1.0 or Hb <80 g/L requires withholding and dose reduction after recovery."
      },
      {
        "rule_id": "ANC_HB_NO_RECOVERY",
        "all": [
          {
            "any": [
              {
                "field": "anc",
                "operator": "<",
                "value": 1.0
              },
              {
                "field": "haemoglobin_g_l",
                "operator": "<",
                "value": 80
              }
            ]
          },
          {
            "field": "haematology_recovered_within_28_days",
            "operator": "==",
            "value": false
          }
        ],
        "action": {
          "type": "discontinue",
          "components": [
            "niraparib"
          ],
          "recommendation": "Discontinue niraparib if ANC/Hb fails to recover within 28 days or if further reduction below 100 mg would be required."
        },
        "source": {
          "page": 4
        },
        "explanation": "Failure of haematologic recovery requires discontinuation."
      },
      {
        "rule_id": "PLATELETS_FIRST_EVENT",
        "all": [
          {
            "field": "platelets",
            "operator": "<",
            "value": 100
          },
          {
            "field": "platelet_event_occurrence",
            "operator": "==",
            "value": "first"
          }
        ],
        "action": {
          "type": "withhold",
          "components": [
            "niraparib"
          ],
          "recommendation": "For a first platelet count <100 ×10⁹/L, withhold for up to 28 days and monitor weekly until recovery to ≥100."
        },
        "source": {
          "page": 4
        },
        "explanation": "First thrombocytopenia occurrence requires withholding."
      },
      {
        "rule_id": "PLATELETS_BELOW_75",
        "field": "platelets",
        "operator": "<",
        "value": 75,
        "action": {
          "type": "withhold_then_reduce",
          "components": [
            "niraparib"
          ],
          "recommendation": "When platelets are <75 ×10⁹/L, resume niraparib one dose level lower after recovery."
        },
        "source": {
          "page": 4
        },
        "explanation": "More severe thrombocytopenia requires dose reduction."
      },
      {
        "rule_id": "PLATELETS_SECOND_EVENT",
        "all": [
          {
            "field": "platelets",
            "operator": "<",
            "value": 100
          },
          {
            "field": "platelet_event_occurrence",
            "operator": "==",
            "value": "second_or_later"
          }
        ],
        "action": {
          "type": "withhold_then_reduce",
          "components": [
            "niraparib"
          ],
          "recommendation": "For a second or later platelet count <100 ×10⁹/L, withhold until recovery and resume one dose level lower."
        },
        "source": {
          "page": 4
        },
        "explanation": "Recurrent thrombocytopenia requires reduction."
      },
      {
        "rule_id": "PLATELETS_NO_RECOVERY",
        "all": [
          {
            "field": "platelets",
            "operator": "<",
            "value": 100
          },
          {
            "field": "haematology_recovered_within_28_days",
            "operator": "==",
            "value": false
          }
        ],
        "action": {
          "type": "discontinue",
          "components": [
            "niraparib"
          ],
          "recommendation": "Discontinue niraparib if platelets fail to recover within 28 days or if the patient is already at 100 mg."
        },
        "source": {
          "page": 4
        },
        "explanation": "Failure to recover or inability to reduce further requires discontinuation."
      },
      {
        "rule_id": "TRANSFUSION_OR_GROWTH_FACTOR",
        "field": "transfusion_or_growth_factor_required",
        "operator": "==",
        "value": true,
        "action": {
          "type": "dose_reduce_one_level",
          "components": [
            "niraparib"
          ],
          "recommendation": "Resume niraparib one dose level lower after a transfusion or haematopoietic growth-factor event."
        },
        "source": {
          "page": 4
        },
        "explanation": "Supportive intervention for haematologic toxicity requires reduction."
      },
      {
        "rule_id": "MDS_AML",
        "field": "confirmed_mds_or_aml",
        "operator": "==",
        "value": true,
        "action": {
          "type": "permanently_discontinue",
          "components": [
            "niraparib"
          ],
          "recommendation": "Permanently discontinue niraparib for confirmed MDS or AML."
        },
        "source": {
          "page": 4
        },
        "explanation": "Confirmed MDS/AML requires permanent discontinuation."
      },
      {
        "rule_id": "RENAL_UNDER_30",
        "field": "crcl_ml_min",
        "operator": "<",
        "value": 30,
        "action": {
          "type": "consultant_review",
          "components": [
            "niraparib"
          ],
          "recommendation": "No automatic niraparib dose reduction is expected at CrCl <30 mL/min, but confirm the plan with the consultant and pharmacy."
        },
        "source": {
          "page": 4
        },
        "explanation": "Severe renal impairment requires specialist review."
      },
      {
        "rule_id": "HAEMODIALYSIS",
        "field": "haemodialysis",
        "operator": "==",
        "value": true,
        "action": {
          "type": "consultant_review",
          "components": [
            "niraparib"
          ],
          "recommendation": "Confirm niraparib treatment in haemodialysis with oncology pharmacy."
        },
        "source": {
          "page": 4
        },
        "explanation": "Dialysis requires specialist review."
      },
      {
        "rule_id": "HEPATIC_MODERATE_SEVERE",
        "field": "hepatic_impairment",
        "operator": "in",
        "value": [
          "moderate",
          "severe"
        ],
        "action": {
          "type": "dose_reduce",
          "components": [
            "niraparib"
          ],
          "recommendation": "Use approximately 66% of the original niraparib dose for moderate or severe hepatic impairment."
        },
        "source": {
          "page": 4
        },
        "explanation": "Moderate/severe hepatic impairment requires reduction."
      },
      {
        "rule_id": "OTHER_AE_FIRST",
        "all": [
          {
            "field": "other_ae_grade",
            "operator": ">=",
            "value": 3
          },
          {
            "field": "other_ae_occurrence",
            "operator": "==",
            "value": "first"
          }
        ],
        "action": {
          "type": "withhold_then_reduce",
          "components": [
            "niraparib"
          ],
          "recommendation": "For a first grade ≥3 non-haematologic adverse event, withhold for up to 28 days until resolution, then resume one dose level lower."
        },
        "source": {
          "page": 4
        },
        "explanation": "First severe non-haematologic toxicity requires withholding and reduction."
      },
      {
        "rule_id": "OTHER_AE_SECOND",
        "all": [
          {
            "field": "other_ae_grade",
            "operator": ">=",
            "value": 3
          },
          {
            "field": "other_ae_occurrence",
            "operator": "==",
            "value": "second"
          }
        ],
        "action": {
          "type": "withhold_then_reduce",
          "components": [

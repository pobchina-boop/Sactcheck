          "components": [
            "carboplatin",
            "pegylated liposomal doxorubicin"
          ],
          "recommendation": "Reduce both PLD and carboplatin by one dose level after grade 4 neutropenia."
        },
        "source": {
          "page": 5
        },
        "explanation": "Grade 4 neutropenia requires one-level reduction."
      },
      {
        "rule_id": "FN_OR_SEVERE_BLEEDING",
        "field": "febrile_neutropenia_or_severe_bleeding",
        "operator": "==",

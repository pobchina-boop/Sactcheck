        "action": {
          "type": "dose_reduce_one_level",
          "components": [
            "carboplatin",
            "pegylated liposomal doxorubicin"
          ],
          "recommendation": "Reduce both PLD and carboplatin by one dose level after febrile neutropenia or severe bleeding."
        },
        "source": {
          "page": 5
        },
        "explanation": "Febrile neutropenia or severe bleeding requires dose reduction."
      },
      {
        "rule_id": "PROLONGED_CYTOPENIA_DELAY",
        "field": "prolonged_cytopenia",
        "operator": "==",
        "value": true,
        "action": {
          "type": "delay",
          "components": [
            "carboplatin",
            "pegylated liposomal doxorubicin"
          ],
          "recommendation": "Delay treatment until full haematologic recovery, for up to 14 days."
        },
        "source": {
          "page": 5
        },
        "explanation": "Prolonged cytopenia requires delay."
      },
      {
        "rule_id": "NO_RECOVERY_AFTER_REDUCTION",
        "all": [
          {
            "field": "prolonged_cytopenia",
            "operator": "==",
            "value": true
          },
          {
            "field": "recovered_after_14_day_delay",
            "operator": "==",
            "value": false
          }
        ],
        "action": {
          "type": "discontinue",
          "components": [
            "pegylated liposomal doxorubicin"
          ],
          "recommendation": "If counts remain inadequate after delay and prior dose reduction, discontinue PLD and consider continuing carboplatin alone after consultant review."
        },
        "source": {
          "page": 5
        },
        "explanation": "Failure to recover after reduction may require stopping PLD."
      },
      {
        "rule_id": "CARBOPLATIN_GFR_20_OR_LESS",
        "field": "gfr_ml_min",
        "operator": "<=",
        "value": 20,
        "action": {
          "type": "contraindicated",
          "components": [
            "carboplatin"
          ],
          "recommendation": "Do not administer carboplatin at GFR ≤20 mL/min."
        },
        "source": {
          "page": 5
        },
        "explanation": "Carboplatin is not recommended at GFR ≤20."
      },
      {
        "rule_id": "CARBOPLATIN_GFR_20_TO_30",
        "all": [
          {
            "field": "gfr_ml_min",
            "operator": ">",
            "value": 20
          },
          {
            "field": "gfr_ml_min",
            "operator": "<=",
            "value": 30
          }
        ],
        "action": {
          "type": "consultant_review",
          "components": [
            "carboplatin"
          ],
          "recommendation": "Use carboplatin with extreme caution at GFR 20–30 mL/min; consultant and pharmacy review required."
        },
        "source": {
          "page": 5
        },
        "explanation": "Severe renal impairment requires extreme caution."
      },
      {
        "rule_id": "PLD_BILIRUBIN_20_51",
        "all": [
          {
            "field": "bilirubin_micromol_l",
            "operator": ">=",
            "value": 20
          },
          {
            "field": "bilirubin_micromol_l",
            "operator": "<=",
            "value": 51
          }
        ],
        "action": {
          "type": "dose_reduce",
          "components": [
            "pegylated liposomal doxorubicin"
          ],
          "recommendation": "Give PLD at 75% for bilirubin 20–51 µmol/L."
        },
        "source": {
          "page": 5
        },
        "explanation": "Moderate hyperbilirubinaemia requires PLD reduction."
      },
      {
        "rule_id": "PLD_BILIRUBIN_OVER_51",
        "field": "bilirubin_micromol_l",
        "operator": ">",
        "value": 51,
        "action": {
          "type": "dose_reduce",
          "components": [
            "pegylated liposomal doxorubicin"
          ],
          "recommendation": "Give PLD at 50% for cycle 1 when bilirubin >51 µmol/L; re-escalation may be considered if tolerated."
        },
        "source": {
          "page": 5
        },
        "explanation": "Severe hyperbilirubinaemia requires a larger initial PLD reduction."
      },

          },
          {
            "field": "toxicity_assessment_week",
            "operator": "in",
            "value": [
              "week4",
              "week5"
            ]
          }
        ],
        "action": {
          "type": "delay",
          "components": [
            "pegylated liposomal doxorubicin"
          ],
          "recommendation": "Delay PLD for one additional week and reassess stomatitis."
        },
        "source": {

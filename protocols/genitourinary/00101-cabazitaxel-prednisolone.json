    "rules": [
      {
        "id": "ANC",
        "priority": 8,
        "when": {
          "field": "anc_x10e9_l",
          "operator": "<",
          "value": 1.5
        },
        "action": {
          "type": "delay",
          "components": [
            "whole_regimen"
          ],
          "message": "Delay one week until ANC >1.5 ×10⁹/L."
        },
        "source": {
          "page": 4,
          "document": "Official NCCP regimen"
        },
        "explanation": "Delay one week until ANC >1.5 ×10⁹/L."
      },
      {
        "id": "PLT",
        "priority": 8,
        "when": {
          "field": "platelets_x10e9_l",
          "operator": "<",
          "value": 100
        },
        "action": {
          "type": "delay",
          "components": [
            "whole_regimen"
          ],
          "message": "Delay until platelets >100 ×10⁹/L."
        },
        "source": {
          "page": 4,
          "document": "Official NCCP regimen"
        },
        "explanation": "Delay until platelets >100 ×10⁹/L."
      },
      {
        "id": "FN",
        "priority": 7,
        "when": {
          "field": "febrile_neutropenia_or_prolonged_grade3",
          "operator": "==",
          "value": true
        },
        "action": {
          "type": "delay_then_dose_reduce",
          "components": [
            "whole_regimen"
          ],
          "message": "Delay until ANC >1.5 then reduce 25→20 mg/m²; for recurrence consider 15 mg/m² or discontinue."
        },
        "source": {
          "page": 4,
          "document": "Official NCCP regimen"
        },
        "explanation": "Delay until ANC >1.5 then reduce 25→20 mg/m²; for recurrence consider 15 mg/m² or discontinue."
      },
      {
        "id": "HEP_MILD",
        "priority": 12,
        "when": {
          "field": "hepatic_band",
          "operator": "==",
          "value": "mild"
        },
        "action": {
          "type": "dose_reduce",
          "components": [
            "whole_regimen"
          ],
          "message": "Use cabazitaxel 20 mg/m²."
        },
        "source": {
          "page": 4,
          "document": "Official NCCP regimen"
        },
        "explanation": "Use cabazitaxel 20 mg/m²."
      },
      {
        "id": "HEP_MOD",
        "priority": 12,
        "when": {
          "field": "hepatic_band",
          "operator": "==",
          "value": "moderate"
        },
        "action": {
          "type": "dose_reduce",
          "components": [
            "whole_regimen"
          ],
          "message": "Use a maximum cabazitaxel dose of 15 mg/m²."
        },
        "source": {
          "page": 4,
          "document": "Official NCCP regimen"
        },
        "explanation": "Use a maximum cabazitaxel dose of 15 mg/m²."
      },
      {
        "id": "HEP_SEVERE",
        "priority": 1,
        "when": {
          "field": "hepatic_band",
          "operator": "==",
          "value": "severe"
        },
        "action": {
          "type": "contraindicated",
          "components": [
            "whole_regimen"
          ],
          "message": "Cabazitaxel is contraindicated when bilirubin >3 ×ULN."
        },
        "source": {
          "page": 4,
          "document": "Official NCCP regimen"
        },
        "explanation": "Cabazitaxel is contraindicated when bilirubin >3 ×ULN."
      },
      {
        "id": "RENAL",
        "priority": 13,
        "when": {
          "field": "renal_band",
          "operator": "in",
          "value": [
            "lt15",
            "dialysis"
          ]
        },
        "action": {
          "type": "proceed_with_caution",
          "components": [
            "whole_regimen"
          ],
          "message": "CrCl <15 mL/min or dialysis requires caution and specialist review."
        },
        "source": {
          "page": 4,
          "document": "Official NCCP regimen"
        },
        "explanation": "CrCl <15 mL/min or dialysis requires caution and specialist review."
      },
      {
        "id": "DIARRHOEA",
        "priority": 7,
        "when": {
          "field": "diarrhoea_grade",
          "operator": ">=",
          "value": 3
        },
        "action": {
          "type": "delay_then_dose_reduce",
          "components": [
            "whole_regimen"
          ],
          "message": "Delay Grade ≥3/persistent diarrhoea until improvement, then reduce 25→20 mg/m²."
        },
        "source": {
          "page": 4,
          "document": "Official NCCP regimen"
        },
        "explanation": "Delay Grade ≥3/persistent diarrhoea until improvement, then reduce 25→20 mg/m²."
      },
      {
        "id": "NEUROPATHY",
        "priority": 7,
        "when": {
          "field": "neuropathy_grade",
          "operator": ">=",
          "value": 2
        },
        "action": {
          "type": "delay_then_dose_reduce",
          "components": [
            "whole_regimen"
          ],
          "message": "Delay Grade ≥2 neuropathy until improvement, then reduce dose."
        },
        "source": {
          "page": 4,
          "document": "Official NCCP regimen"
        },
        "explanation": "Delay Grade ≥2 neuropathy until improvement, then reduce dose."
      },
      {
        "id": "STOMATITIS3",
        "priority": 5,
        "when": {
          "field": "stomatitis_grade",
          "operator": "==",
          "value": 3
        },
        "action": {
          "type": "withhold_then_reduce",
          "components": [
            "whole_regimen"
          ],
          "message": "Withhold Grade 3 stomatitis until Grade ≤1, then resume at 20 mg/m²."
        },
        "source": {
          "page": 4,
          "document": "Official NCCP regimen"
        },
        "explanation": "Withhold Grade 3 stomatitis until Grade ≤1, then resume at 20 mg/m²."
      },
      {
        "id": "STOMATITIS4",
        "priority": 2,
        "when": {
          "field": "stomatitis_grade",
          "operator": ">=",
          "value": 4
        },
        "action": {
          "type": "discontinue",
          "components": [
            "whole_regimen"
          ],
          "message": "Discontinue for Grade 4 stomatitis."
        },
        "source": {
          "page": 4,
          "document": "Official NCCP regimen"
        },
        "explanation": "Discontinue for Grade 4 stomatitis."
      },
      {
        "id": "HSR",
        "priority": 2,
        "when": {
          "field": "hypersensitivity_reaction",
          "operator": "==",
          "value": true
        },
        "action": {
          "type": "discontinue",
          "components": [
            "whole_regimen"
          ],
          "message": "Discontinue for severe hypersensitivity."
        },
        "source": {
          "page": 5,
          "document": "Official NCCP regimen"
        },
        "explanation": "Discontinue for severe hypersensitivity."
      }
    ]
  },
